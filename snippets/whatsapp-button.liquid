{%- assign wa_number = settings.wa_number | default: '5562994319090' -%}
{%- assign wa_agent = settings.wa_agent_name | default: 'Musas Atendimento' -%}
{%- assign wa_status = settings.wa_status | default: 'Offline' -%}
{%- assign wa_welcome = settings.wa_welcome | default: '👋 Olá! Bem-vindo à Musas! Como posso ajudar você hoje?' -%}
{%- assign wa_default_msg = settings.wa_default_msg | default: 'Olá! Vim pelo site e gostaria de mais informações.' -%}
{%- assign wa_footer = settings.wa_footer | default: 'Resposta em até 2 horas durante horário comercial' -%}
{%- assign wa_show_delay = settings.wa_show_delay | default: 3 -%}
{%- assign wa_hide_after = settings.wa_hide_after | default: 5 -%}
{%- assign wa_repeat_after = settings.wa_repeat_after | default: 30 -%}

<!-- Google Fonts for widget -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
.wac-widget *{box-sizing:border-box;margin:0;padding:0;font-family:'Inter',system-ui,sans-serif;}

/* FAB */
.wac-fab-area{position:fixed;bottom:1.75rem;right:1.75rem;z-index:9999;display:flex;flex-direction:column;align-items:flex-end;gap:.6rem;}
.wac-bubble{background:#fff;color:#111;font-size:.875rem;font-weight:500;padding:.55rem 1rem;border-radius:1.25rem 1.25rem 0 1.25rem;box-shadow:0 4px 20px rgba(0,0,0,.13);max-width:220px;line-height:1.4;opacity:0;transform:translateY(8px) scale(.95);transition:opacity .35s ease,transform .35s ease;pointer-events:none;}
.wac-bubble.show{opacity:1;transform:translateY(0) scale(1);pointer-events:auto;}
.wac-fab{width:60px;height:60px;border-radius:9999px;background:linear-gradient(135deg,#7c3aed,#9f5cf7);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 6px 24px rgba(124,58,237,.45);transition:transform .2s ease,box-shadow .2s ease;position:relative;}
.wac-fab:hover{transform:scale(1.1);box-shadow:0 8px 32px rgba(124,58,237,.6);}
.wac-fab-pulse{position:absolute;inset:0;border-radius:9999px;background:rgba(124,58,237,.35);animation:wacPulse 2s ease-out infinite;}
@keyframes wacPulse{0%{transform:scale(1);opacity:.7;}100%{transform:scale(1.7);opacity:0;}}

/* Panel */
.wac-panel{position:fixed;bottom:5.5rem;right:1.75rem;z-index:9998;width:340px;border-radius:1.25rem;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,.18),0 4px 16px rgba(0,0,0,.1);background:#f0f2f5;opacity:0;transform:translateY(20px) scale(.97);pointer-events:none;transition:opacity .3s ease,transform .3s ease;}
.wac-panel.open{opacity:1;transform:translateY(0) scale(1);pointer-events:all;}

/* Header */
.wac-header{background:linear-gradient(135deg,#6d28d9,#7c3aed);padding:1rem 1.1rem;display:flex;align-items:center;gap:.75rem;}
.wac-avatar{width:46px;height:46px;border-radius:9999px;background:rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center;flex-shrink:0;position:relative;}
.wac-avatar-online{position:absolute;bottom:1px;right:1px;width:11px;height:11px;border-radius:9999px;background:#4ade80;border:2px solid #7c3aed;}
.wac-header-info{flex:1;}
.wac-header-name{color:#fff;font-size:.9375rem;font-weight:700;line-height:1.2;}
.wac-header-status{color:rgba(255,255,255,.75);font-size:.75rem;margin-top:.15rem;display:flex;align-items:center;gap:.3rem;}
.wac-header-status::before{content:'';width:7px;height:7px;border-radius:9999px;background:#4ade80;display:inline-block;}
.wac-close{background:rgba(255,255,255,.15);border:none;color:#fff;width:30px;height:30px;border-radius:9999px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background .2s;flex-shrink:0;}
.wac-close:hover{background:rgba(255,255,255,.3);}

/* Messages area */
.wac-messages{padding:1rem;display:flex;flex-direction:column;gap:.75rem;max-height:220px;overflow-y:auto;background:#f0f2f5;}
.wac-messages::-webkit-scrollbar{width:4px;}
.wac-messages::-webkit-scrollbar-thumb{background:rgba(0,0,0,.15);border-radius:9999px;}
.wac-msg-in{background:#fff;border-radius:0 1rem 1rem 1rem;padding:.75rem .9rem;font-size:.875rem;line-height:1.5;color:#111;box-shadow:0 1px 4px rgba(0,0,0,.07);max-width:90%;position:relative;}
.wac-msg-in::before{content:'';position:absolute;top:0;left:-6px;border:6px solid transparent;border-right-color:#fff;border-top-color:#fff;}
.wac-msg-time{font-size:.7rem;color:#999;text-align:right;margin-top:.35rem;}
.wac-typing{display:flex;align-items:center;gap:.3rem;padding:.5rem .75rem;background:#fff;border-radius:0 1rem 1rem 1rem;width:fit-content;box-shadow:0 1px 4px rgba(0,0,0,.07);}
.wac-typing span{width:7px;height:7px;border-radius:9999px;background:#aaa;animation:wacDot 1.2s infinite;}
.wac-typing span:nth-child(2){animation-delay:.2s;}
.wac-typing span:nth-child(3){animation-delay:.4s;}
@keyframes wacDot{0%,60%,100%{transform:translateY(0);}30%{transform:translateY(-5px);}}

/* Quick actions */
.wac-quick{padding:.5rem 1rem 1rem;display:grid;grid-template-columns:1fr 1fr;gap:.5rem;background:#f0f2f5;}
.wac-quick-btn{background:#fff;border:1.5px solid #e5e7eb;border-radius:.875rem;padding:.7rem .75rem;cursor:pointer;display:flex;flex-direction:column;align-items:flex-start;gap:.15rem;transition:all .2s;text-align:left;}
.wac-quick-btn:hover{border-color:#7c3aed;background:#faf5ff;transform:translateY(-1px);box-shadow:0 4px 12px rgba(124,58,237,.12);}
.wac-quick-icon{font-size:1.25rem;margin-bottom:.2rem;}
.wac-quick-label{font-size:.8125rem;font-weight:700;color:#7c3aed;}
.wac-quick-sub{font-size:.7rem;color:#6b7280;}

/* Input area */
.wac-input-area{background:#fff;padding:.75rem 1rem;border-top:1px solid #e5e7eb;display:flex;flex-direction:column;gap:.6rem;}
.wac-textarea{width:100%;border:1.5px solid #e5e7eb;border-radius:.75rem;padding:.65rem .875rem;font-size:.875rem;color:#111;resize:none;outline:none;transition:border-color .2s;line-height:1.5;background:#fafafa;}
.wac-textarea:focus{border-color:#7c3aed;background:#fff;}
.wac-textarea::placeholder{color:#9ca3af;}
.wac-send{width:100%;padding:.75rem;background:linear-gradient(135deg,#6d28d9,#7c3aed);color:#fff;border:none;border-radius:.875rem;font-size:.875rem;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:.5rem;transition:filter .2s,transform .15s;letter-spacing:.02em;}
.wac-send:hover{filter:brightness(1.1);transform:translateY(-1px);}
.wac-send:active{transform:translateY(0);}

/* Footer */
.wac-footer{background:#fff;text-align:center;padding:.6rem 1rem;font-size:.7rem;color:#9ca3af;border-top:1px solid #f3f4f6;}
</style>

<div class="wac-widget">

  <!-- FAB -->
  <div class="wac-fab-area" id="wac-fab-area">
    <div class="wac-bubble" id="wac-bubble"></div>
    <button class="wac-fab" id="wac-fab" onclick="wacToggle()" aria-label="Abrir chat">
      <div class="wac-fab-pulse"></div>
      <svg width="30" height="30" viewBox="0 0 32 32" fill="none">
        <path d="M16 2C8.27 2 2 8.27 2 16c0 2.48.65 4.8 1.78 6.82L2 30l7.38-1.75A14 14 0 0 0 16 30c7.73 0 14-6.27 14-14S23.73 2 16 2z" fill="#fff"/>
        <path d="M23.1 19.6c-.3-.15-1.77-.87-2.04-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.27-.47-2.42-1.49-.9-.8-1.5-1.78-1.68-2.08-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.8.37-.27.3-1.04 1.02-1.04 2.48s1.07 2.87 1.22 3.07c.15.2 2.1 3.2 5.08 4.49.71.31 1.27.49 1.7.63.72.23 1.37.2 1.88.12.57-.09 1.77-.72 2.02-1.42.25-.7.25-1.3.17-1.42-.07-.12-.27-.2-.57-.35z" fill="#7c3aed"/>
      </svg>
    </button>
  </div>

  <!-- Panel -->
  <div class="wac-panel" id="wac-panel">
    <div class="wac-header">
      <div class="wac-avatar">
        <svg width="24" height="24" viewBox="0 0 32 32" fill="none">
          <path d="M16 2C8.27 2 2 8.27 2 16c0 2.48.65 4.8 1.78 6.82L2 30l7.38-1.75A14 14 0 0 0 16 30c7.73 0 14-6.27 14-14S23.73 2 16 2z" fill="#fff" fill-opacity=".3"/>
          <path d="M23.1 19.6c-.3-.15-1.77-.87-2.04-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.27-.47-2.42-1.49-.9-.8-1.5-1.78-1.68-2.08-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.8.37-.27.3-1.04 1.02-1.04 2.48s1.07 2.87 1.22 3.07c.15.2 2.1 3.2 5.08 4.49.71.31 1.27.49 1.7.63.72.23 1.37.2 1.88.12.57-.09 1.77-.72 2.02-1.42.25-.7.25-1.3.17-1.42-.07-.12-.27-.2-.57-.35z" fill="#fff"/>
        </svg>
        <div class="wac-avatar-online"></div>
      </div>
      <div class="wac-header-info">
        <div class="wac-header-name">{{ wa_agent }}</div>
        <div class="wac-header-status">{{ wa_status }}</div>
      </div>
      <button class="wac-close" onclick="wacToggle()" aria-label="Fechar">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <div class="wac-messages" id="wac-messages">
      <div class="wac-typing" id="wac-typing">
        <span></span><span></span><span></span>
      </div>
    </div>

    <div class="wac-quick">
      <button class="wac-quick-btn" onclick="wacSend('Quero rastrear meu pedido')">
        <span class="wac-quick-icon">📦</span>
        <span class="wac-quick-label">Rastrear</span>
        <span class="wac-quick-sub">Meu pedido</span>
      </button>
      <button class="wac-quick-btn" onclick="wacSend('Quero calcular o frete')">
        <span class="wac-quick-icon">🚚</span>
        <span class="wac-quick-label">Calcular</span>
        <span class="wac-quick-sub">Frete</span>
      </button>
      <button class="wac-quick-btn" onclick="wacSend('Quero informações sobre trocas e devoluções')">
        <span class="wac-quick-icon">🔄</span>
        <span class="wac-quick-label">Trocas</span>
        <span class="wac-quick-sub">e devoluções</span>
      </button>
      <button class="wac-quick-btn" onclick="wacSend('Quero ver os produtos disponíveis')">
        <span class="wac-quick-icon">👗</span>
        <span class="wac-quick-label">Produtos</span>
        <span class="wac-quick-sub">Ver catálogo</span>
      </button>
    </div>

    <div class="wac-input-area">
      <textarea class="wac-textarea" id="wac-textarea" placeholder="Digite sua mensagem..." rows="2"></textarea>
      <button class="wac-send" onclick="wacSendCustom()">
        <svg width="18" height="18" viewBox="0 0 32 32" fill="none"><path d="M16 2C8.27 2 2 8.27 2 16c0 2.48.65 4.8 1.78 6.82L2 30l7.38-1.75A14 14 0 0 0 16 30c7.73 0 14-6.27 14-14S23.73 2 16 2z" fill="#fff" fill-opacity=".2"/><path d="M23.1 19.6c-.3-.15-1.77-.87-2.04-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.27-.47-2.42-1.49-.9-.8-1.5-1.78-1.68-2.08-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.8.37-.27.3-1.04 1.02-1.04 2.48s1.07 2.87 1.22 3.07c.15.2 2.1 3.2 5.08 4.49.71.31 1.27.49 1.7.63.72.23 1.37.2 1.88.12.57-.09 1.77-.72 2.02-1.42.25-.7.25-1.3.17-1.42-.07-.12-.27-.2-.57-.35z" fill="#fff"/></svg>
        Enviar no WhatsApp
      </button>
    </div>

    <div class="wac-footer">{{ wa_footer }}</div>
  </div>
</div>

<script>
(function(){
  var NUM = '{{ wa_number }}';
  var SHOW_DELAY = {{ wa_show_delay }} * 1000;
  var HIDE_AFTER = {{ wa_hide_after }} * 1000;
  var REPEAT_AFTER = {{ wa_repeat_after }} * 1000;
  var WELCOME = '{{ wa_welcome | escape }}';
  var DEFAULT_MSG = '{{ wa_default_msg | escape }}';

  var rawMsgs = {{ settings.wa_bubble_messages | default: 'Precisa rastrear seu pedido? 📦\nFrete grátis acima de R$299! 🚚\nTroca fácil em até 30 dias! 🔄' | newline_to_br | split: '<br />' | json }};
  var cycleMessages = rawMsgs.map(function(m){ return m.replace(/\r?\n/g,'').trim(); }).filter(Boolean);

  // Time greeting
  var h = new Date().getHours();
  var greeting = h>=5&&h<12?'Bom dia! ☀️':h>=12&&h<18?'Boa tarde! 👋':'Boa noite! 🌙';

  // Persist index
  var KEY = 'wac_idx';
  var idx = 0;
  try {
    var s = parseInt(localStorage.getItem(KEY),10);
    if(!isNaN(s) && cycleMessages.length>0) idx = (s+1)%cycleMessages.length;
  } catch(e){}

  // Show welcome message with typing animation
  var opened = false;
  window.wacToggle = function(){
    var panel = document.getElementById('wac-panel');
    var fab = document.getElementById('wac-fab-area');
    var isOpen = panel.classList.toggle('open');
    fab.style.display = isOpen ? 'none' : 'flex';
    hideBubble();
    if(isOpen && !opened){
      opened = true;
      showTypingThenMsg();
    }
  };

  function showTypingThenMsg(){
    var typing = document.getElementById('wac-typing');
    var msgs = document.getElementById('wac-messages');
    if(typing) typing.style.display = 'flex';
    setTimeout(function(){
      if(typing) typing.style.display = 'none';
      var div = document.createElement('div');
      div.className = 'wac-msg-in';
      div.innerHTML = WELCOME + '<div class="wac-msg-time">' + greeting + '</div>';
      if(msgs){ msgs.appendChild(div); msgs.scrollTop = msgs.scrollHeight; }
    }, 1200);
  }

  // Bubble cycle
  var hideTimer, repeatTimer;
  function showBubble(){
    var el = document.getElementById('wac-bubble');
    var panel = document.getElementById('wac-panel');
    if(!el || panel.classList.contains('open')) return;
    var msg = cycleMessages.length>0 ? cycleMessages[idx%cycleMessages.length] : greeting;
    try{ localStorage.setItem(KEY, idx%(cycleMessages.length||1)); }catch(e){}
    idx++;
    el.textContent = msg;
    el.classList.add('show');
    clearTimeout(hideTimer);
    hideTimer = setTimeout(function(){
      el.classList.remove('show');
      clearTimeout(repeatTimer);
      repeatTimer = setTimeout(showBubble, REPEAT_AFTER);
    }, HIDE_AFTER);
  }

  function hideBubble(){
    var el = document.getElementById('wac-bubble');
    if(el) el.classList.remove('show');
    clearTimeout(hideTimer); clearTimeout(repeatTimer);
  }

  setTimeout(showBubble, SHOW_DELAY);

  window.wacSend = function(msg){
    window.open('https://wa.me/'+NUM+'?text='+encodeURIComponent(msg),'_blank');
  };
  window.wacSendCustom = function(){
    var v = document.getElementById('wac-textarea').value.trim();
    wacSend(v || DEFAULT_MSG);
  };
})();
</script>
