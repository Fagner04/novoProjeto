{%- assign wa_number = settings.wa_number | default: '5562994319090' -%}
{%- assign wa_agent = settings.wa_agent_name | default: 'Musas Atendimento' -%}
{%- assign wa_status = settings.wa_status | default: 'Offline' -%}
{%- assign wa_welcome = settings.wa_welcome | default: '👋 Olá! Bem-vindo à Musas! Como posso ajudar você hoje?' -%}
{%- assign wa_default_msg = settings.wa_default_msg | default: 'Olá! Vim pelo site e gostaria de mais informações.' -%}
{%- assign wa_footer = settings.wa_footer | default: 'Resposta em até 2 horas durante horário comercial' -%}
{%- assign wa_show_delay = settings.wa_show_delay | default: 3 -%}
{%- assign wa_hide_after = settings.wa_hide_after | default: 5 -%}
{%- assign wa_repeat_after = settings.wa_repeat_after | default: 30 -%}
{%- assign wa_bubble_raw = settings.wa_bubble_messages | default: 'Precisa rastrear seu pedido? 📦\nFrete grátis acima de R$299! 🚚\nTroca fácil em até 30 dias! 🔄' -%}

<div class="wa-widget" id="wa-widget">

  <div class="wa-fab-wrap" id="wa-fab-wrap">
    <div class="wa-greeting-bubble" id="wa-greeting" style="display:none;"></div>
    <button class="wa-fab" id="wa-fab-btn" onclick="toggleWaChat()" aria-label="Abrir chat WhatsApp">
      <svg width="28" height="28" viewBox="0 0 32 32" fill="none">
        <path d="M16 2C8.268 2 2 8.268 2 16c0 2.478.648 4.805 1.782 6.82L2 30l7.38-1.754A13.94 13.94 0 0 0 16 30c7.732 0 14-6.268 14-14S23.732 2 16 2z" fill="#fff"/>
        <path d="M23.1 19.6c-.3-.15-1.77-.87-2.04-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.27-.47-2.42-1.49-.9-.8-1.5-1.78-1.68-2.08-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.51-.17-.01-.37-.01-.57-.01-.2 0-.52.07-.8.37-.27.3-1.04 1.02-1.04 2.48 0 1.46 1.07 2.87 1.22 3.07.15.2 2.1 3.2 5.08 4.49.71.31 1.27.49 1.7.63.72.23 1.37.2 1.88.12.57-.09 1.77-.72 2.02-1.42.25-.7.25-1.3.17-1.42-.07-.12-.27-.2-.57-.35z" fill="#7c3aed"/>
      </svg>
    </button>
  </div>

  <div class="wa-panel" id="wa-panel">
    <div class="wa-panel-header">
      <div class="wa-panel-avatar">
        <svg width="26" height="26" viewBox="0 0 32 32" fill="none">
          <path d="M16 2C8.268 2 2 8.268 2 16c0 2.478.648 4.805 1.782 6.82L2 30l7.38-1.754A13.94 13.94 0 0 0 16 30c7.732 0 14-6.268 14-14S23.732 2 16 2z" fill="#fff" fill-opacity=".25"/>
          <path d="M23.1 19.6c-.3-.15-1.77-.87-2.04-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.27-.47-2.42-1.49-.9-.8-1.5-1.78-1.68-2.08-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.51-.17-.01-.37-.01-.57-.01-.2 0-.52.07-.8.37-.27.3-1.04 1.02-1.04 2.48 0 1.46 1.07 2.87 1.22 3.07.15.2 2.1 3.2 5.08 4.49.71.31 1.27.49 1.7.63.72.23 1.37.2 1.88.12.57-.09 1.77-.72 2.02-1.42.25-.7.25-1.3.17-1.42-.07-.12-.27-.2-.57-.35z" fill="#fff"/>
        </svg>
      </div>
      <div class="wa-panel-info">
        <strong>{{ wa_agent }}</strong>
        <span class="wa-status"><span class="wa-dot"></span> {{ wa_status }}</span>
      </div>
      <button class="wa-close-btn" onclick="toggleWaChat()" aria-label="Fechar">✕</button>
    </div>

    <div class="wa-panel-body">
      <div class="wa-welcome-msg">
        <p>{{ wa_welcome }}</p>
        <span class="wa-time-label" id="wa-time-label"></span>
      </div>

      <div class="wa-quick-actions">
        <button class="wa-quick-btn" onclick="sendWaMsg('Quero rastrear meu pedido')">
          <span class="wa-quick-icon">📦</span>
          <strong>Rastrear</strong>
          <small>Meu pedido</small>
        </button>
        <button class="wa-quick-btn" onclick="sendWaMsg('Quero calcular o frete')">
          <span class="wa-quick-icon">🧮</span>
          <strong>Calcular</strong>
          <small>Frete</small>
        </button>
        <button class="wa-quick-btn" onclick="sendWaMsg('Quero informações sobre trocas')">
          <span class="wa-quick-icon">🔄</span>
          <strong>Trocas</strong>
          <small>e devoluções</small>
        </button>
      </div>

      <textarea class="wa-textarea" id="wa-textarea" placeholder="Digite sua mensagem..." rows="3"></textarea>

      <button class="wa-send-btn" onclick="sendWaCustom()">
        <svg width="18" height="18" viewBox="0 0 32 32" fill="none"><path d="M16 2C8.268 2 2 8.268 2 16c0 2.478.648 4.805 1.782 6.82L2 30l7.38-1.754A13.94 13.94 0 0 0 16 30c7.732 0 14-6.268 14-14S23.732 2 16 2z" fill="#fff" fill-opacity=".25"/><path d="M23.1 19.6c-.3-.15-1.77-.87-2.04-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.27-.47-2.42-1.49-.9-.8-1.5-1.78-1.68-2.08-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.51-.17-.01-.37-.01-.57-.01-.2 0-.52.07-.8.37-.27.3-1.04 1.02-1.04 2.48 0 1.46 1.07 2.87 1.22 3.07.15.2 2.1 3.2 5.08 4.49.71.31 1.27.49 1.7.63.72.23 1.37.2 1.88.12.57-.09 1.77-.72 2.02-1.42.25-.7.25-1.3.17-1.42-.07-.12-.27-.2-.57-.35z" fill="#fff"/></svg>
        Enviar no WhatsApp →
      </button>
    </div>

    <div class="wa-panel-footer">{{ wa_footer }}</div>
  </div>
</div>

<script>
(function() {
  var WA_NUMBER = '{{ wa_number }}';
  var SHOW_DELAY = {{ wa_show_delay }} * 1000;
  var HIDE_AFTER = {{ wa_hide_after }} * 1000;
  var REPEAT_AFTER = {{ wa_repeat_after }} * 1000;

  var cycleMessages = {{ wa_bubble_raw | newline_to_br | split: '<br />' | json }};
  cycleMessages = cycleMessages.map(function(m){ return m.replace(/\r?\n/g,'').trim(); }).filter(Boolean);

  var h = new Date().getHours();
  var timeGreeting = h >= 5 && h < 12 ? 'Bom dia! ☀️' : h >= 12 && h < 18 ? 'Boa tarde! 👋' : 'Boa noite! 🌙';
  var timeEl = document.getElementById('wa-time-label');
  if (timeEl) timeEl.textContent = timeGreeting;

  var STORAGE_KEY = 'wa_msg_index';
  var msgIndex = 0;
  try {
    var stored = parseInt(localStorage.getItem(STORAGE_KEY), 10);
    if (!isNaN(stored) && cycleMessages.length > 0) {
      msgIndex = (stored + 1) % cycleMessages.length;
    }
  } catch(e) {}

  var hideTimer, repeatTimer;

  function showBubble() {
    var el = document.getElementById('wa-greeting');
    var panel = document.getElementById('wa-panel');
    if (!el || panel.classList.contains('open')) return;
    var msg = cycleMessages.length > 0 ? cycleMessages[msgIndex % cycleMessages.length] : timeGreeting;
    try { localStorage.setItem(STORAGE_KEY, msgIndex % (cycleMessages.length || 1)); } catch(e) {}
    msgIndex++;
    el.textContent = msg;
    el.style.display = 'block';
    el.style.opacity = '1';
    clearTimeout(hideTimer);
    hideTimer = setTimeout(function() {
      el.style.opacity = '0';
      setTimeout(function() { el.style.display = 'none'; }, 400);
    }, HIDE_AFTER);
    clearTimeout(repeatTimer);
    repeatTimer = setTimeout(showBubble, HIDE_AFTER + REPEAT_AFTER);
  }

  setTimeout(showBubble, SHOW_DELAY);

  window.toggleWaChat = function() {
    var panel = document.getElementById('wa-panel');
    var fabWrap = document.getElementById('wa-fab-wrap');
    var open = panel.classList.toggle('open');
    fabWrap.style.display = open ? 'none' : 'flex';
    var el = document.getElementById('wa-greeting');
    if (el) { el.style.opacity = '0'; el.style.display = 'none'; }
  };

  window.sendWaMsg = function(msg) {
    window.open('https://wa.me/' + WA_NUMBER + '?text=' + encodeURIComponent(msg), '_blank');
  };

  window.sendWaCustom = function() {
    var msg = document.getElementById('wa-textarea').value.trim();
    if (!msg) msg = '{{ wa_default_msg | escape }}';
    window.sendWaMsg(msg);
  };
})();
</script>
