<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#fe7e41">
  <title>{{ page_title }} - {{ shop.name }}</title>
  <meta name="description" content="{{ page_description | escape }}">

  {{ content_for_header }}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Merriweather:wght@300;400;700&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  {{ 'theme.css' | asset_url | stylesheet_tag }}
  <style>
    :root {
      --brand-orange: {{ settings.color_primary }};
      --brand-purple: {{ settings.color_secondary }};
      --background: {{ settings.color_background }};
      --foreground: {{ settings.color_foreground }};
      --header-bg: {{ settings.color_header_bg }};
      --header-text: {{ settings.color_header_text }};
      --header-icons: {{ settings.color_header_icons }};
      --badge-cart-bg: {{ settings.color_badge_cart_bg }};
      --badge-cart-text: {{ settings.color_badge_cart_text }};
      --cart-bg: {{ settings.color_cart_bg }};
      --cart-text: {{ settings.color_cart_text }};
      --cart-btn-bg: {{ settings.color_cart_btn_bg }};
      --cart-btn-text: {{ settings.color_cart_btn_text }};
      --header-opacity: {{ settings.header_opacity | divided_by: 100.0 }};
      --footer-bg: {{ settings.color_footer_bg }};
      --footer-text: {{ settings.color_footer_text }};
      --btn-bg: {{ settings.color_btn_bg }};
      --btn-text: {{ settings.color_btn_text }};
      --tab-active-bg: {{ settings.color_tab_active }};
      --tab-active-text: {{ settings.color_tab_active_text }};
      --pix-color: {{ settings.color_pix }};
      --badge-bg: {{ settings.color_badge_bg }};
    }
  </style>
</head>
<body>

<!-- THEME ACTIVATION GATE -->
{% assign _tk = settings.theme_activation_token | strip %}
{% if _tk != blank %}
<script>
(function(){
  var KEY='_theme_activated';
  var API='https://conectwhats.vercel.app/api/activate';
  var STORED_TOKEN={{ _tk | json }};

  if(localStorage.getItem(KEY)==='1'){return;}

  // Verifica o token das settings automaticamente
  fetch(API,{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({token:STORED_TOKEN,domain:location.hostname})
  }).then(function(r){return r.json();}).then(function(d){
    if(d.ok||d.domain_active){
      localStorage.setItem(KEY,'1');
    }
  }).catch(function(){});
})();
</script>
{% else %}
<div id="_ag" style="display:none;position:fixed;inset:0;background:#f4f4f5;z-index:99999;align-items:center;justify-content:center;font-family:'Poppins',sans-serif;">
  <div id="_af" style="background:#fff;border-radius:1.25rem;padding:2.5rem 2rem;max-width:420px;width:90%;box-shadow:0 8px 40px rgba(0,0,0,.12);text-align:center;">
    <div style="font-size:2.5rem;margin-bottom:1rem;">🔑</div>
    <h2 style="font-size:1.25rem;font-weight:700;margin-bottom:.5rem;color:#18181b;">Theme Activation Required</h2>
    <p style="color:#52525b;font-size:.875rem;margin-bottom:1.5rem;">Enter your activation token to unlock this theme.</p>
    <input id="_at" type="text" placeholder="Paste your activation token..." autocomplete="off" spellcheck="false"
      style="width:100%;padding:.8rem 1rem;border:2px solid #d4d4d8;border-radius:.75rem;font-size:.9rem;outline:none;text-align:center;box-sizing:border-box;margin-bottom:.75rem;">
    <button id="_ab" onclick="_av()"
      style="width:100%;padding:.85rem;background:#fe7e41;color:#fff;border:none;border-radius:9999px;font-size:.9rem;font-weight:600;cursor:pointer;">
      Activate Theme
    </button>
    <p id="_ae" style="display:none;margin-top:.7rem;color:#ef4444;font-size:.8rem;background:#fef2f2;border-radius:.5rem;padding:.5rem .75rem;"></p>
  </div>
  <div id="_as" style="display:none;background:#fff;border-radius:1.25rem;padding:2.5rem 2rem;max-width:420px;width:90%;box-shadow:0 8px 40px rgba(0,0,0,.12);text-align:center;border-top:4px solid #22c55e;">
    <div style="font-size:3rem;margin-bottom:1rem;">🎉</div>
    <h2 style="font-size:1.25rem;font-weight:700;margin-bottom:.5rem;color:#18181b;">Parabéns! Tema Ativado!</h2>
    <p style="color:#52525b;font-size:.875rem;margin-bottom:1.5rem;">Seu tema está online e pronto para uso.</p>
    <button onclick="_ac()"
      style="width:100%;padding:.85rem;background:#22c55e;color:#fff;border:none;border-radius:9999px;font-size:.9rem;font-weight:600;cursor:pointer;">
      Acessar minha loja →
    </button>
  </div>
</div>
<script>
(function(){
  var KEY='_theme_activated';
  var API='https://conectwhats.vercel.app/api/activate';
  if(localStorage.getItem(KEY)==='1'){return;}
  var gate=document.getElementById('_ag');
  gate.style.display='flex';
  document.body.style.overflow='hidden';
  window._av=async function(){
    var t=document.getElementById('_at').value.trim();
    var b=document.getElementById('_ab');
    var e=document.getElementById('_ae');
    if(!t){_showErr('Please enter your activation token.');return;}
    b.disabled=true;b.textContent='Activating...';e.style.display='none';
    try{
      var r=await fetch(API,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({token:t,domain:location.hostname})});
      var d=await r.json();
      if(!r.ok){_showErr(d.error||'Invalid token.');return;}
      localStorage.setItem(KEY,'1');
      document.getElementById('_af').style.display='none';
      document.getElementById('_as').style.display='block';
      setTimeout(function(){gate.style.display='none';document.body.style.overflow='';},3000);
    }catch(x){_showErr('Connection error. Please try again.');}
    finally{b.disabled=false;b.textContent='Activate Theme';}
  };
  function _showErr(m){var e=document.getElementById('_ae');e.textContent=m;e.style.display='block';document.getElementById('_ab').disabled=false;document.getElementById('_ab').textContent='Activate Theme';}
  window._ac=function(){gate.style.display='none';document.body.style.overflow='';};
  document.getElementById('_at').addEventListener('keydown',function(e){if(e.key==='Enter')_av();});
})();
</script>
{% endif %}
<!-- END ACTIVATION GATE -->
  {% section 'announcement-bar' %}
  {% section 'header' %}

  <main id="main-content" style="padding-top:0;">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  <!-- Cart Drawer -->
  {% render 'cart-drawer' %}

  <!-- Cookie Banner -->
  {% render 'cookie-banner' %}

  <!-- WhatsApp Chat -->
  {% render 'whatsapp-button' %}

  <!-- Promo Popup -->
  {% render 'promo-popup' %}
  {% render 'conectwhats-checkout' %}

  <script src="{{ 'theme.js' | asset_url }}?v={{ 'now' | date: '%s' }}" defer></script>
  <script>
    function setHeaderHeight(){
      var ann=document.getElementById('announcement-bar');
      var hdr=document.getElementById('site-header');
      var annH=ann?ann.offsetHeight:0;
      var hdrH=hdr?hdr.offsetHeight:0;
      document.documentElement.style.setProperty('--header-h',(annH+hdrH)+'px');
    }
    document.addEventListener('DOMContentLoaded',setHeaderHeight);
    window.addEventListener('resize',setHeaderHeight);
  </script>
  <script>
    window.__cwAtacado = {
      enabled: {{ settings.conectwhats_atacado_enabled | json }},
      min_qty: {{ settings.conectwhats_atacado_min_qty | default: 6 }}
    };
    window.__cwAcessorio = {
      enabled: {{ settings.atacado_acessorio_enabled | json }},
      tag: {{ settings.atacado_acessorio_tag | default: 'acessorio' | json }},
      min_value: parseFloat({{ settings.atacado_acessorio_min_value | default: '100.00' | json }}) * 100
    };
    window._tagsCache = {};
    window.getProductTags = function(handle) {
      if (window._tagsCache[handle] !== undefined) return Promise.resolve(window._tagsCache[handle]);
      return fetch('/products/' + handle + '.js')
        .then(function(r){ return r.json(); })
        .then(function(p){
          window._tagsCache[handle] = (p.tags || []).map(function(t){ return t.toLowerCase().trim(); });
          return window._tagsCache[handle];
        })
        .catch(function(){ window._tagsCache[handle] = []; return []; });
    };
  </script>
</body>
</html>
