<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ shop.name }} — Em Breve</title>
  <meta name="description" content="Nossa loja está sendo preparada com muito carinho. Em breve novidades!">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  {{ content_for_header }}
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Poppins', sans-serif;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #f2f2f3;
      overflow: hidden;
    }

    /* Fundo animado */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background: linear-gradient(135deg, #7c3aed22 0%, #fe7e4122 50%, #f5c84222 100%);
      animation: bgShift 8s ease infinite alternate;
      z-index: 0;
    }
    @keyframes bgShift {
      0%   { opacity: 0.4; transform: scale(1); }
      100% { opacity: 1;   transform: scale(1.05); }
    }

    .pw-card {
      position: relative;
      z-index: 1;
      background: #fff;
      border-radius: 1.5rem;
      padding: 3rem 2.5rem;
      max-width: 460px;
      width: 90%;
      box-shadow: 0 24px 64px rgba(0,0,0,0.10), 0 4px 16px rgba(124,58,237,0.08);
      text-align: center;
    }

    /* Logo / nome animado */
    .pw-brand {
      font-size: 2.25rem;
      font-weight: 700;
      letter-spacing: .04em;
      background: linear-gradient(270deg, #7c3aed, #fe7e41, #f5c842, #fe7e41, #7c3aed);
      background-size: 300% 300%;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: gradAnim 4s ease infinite;
      margin-bottom: .25rem;
    }
    @keyframes gradAnim {
      0%   { background-position: 0% 50%; }
      50%  { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }

    .pw-tagline {
      font-size: .875rem;
      color: #71717a;
      margin-bottom: 2rem;
      font-weight: 400;
    }

    /* Ícone de cadeado */
    .pw-icon {
      width: 64px;
      height: 64px;
      background: linear-gradient(135deg, #7c3aed, #fe7e41);
      border-radius: 9999px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1.5rem;
      box-shadow: 0 8px 24px rgba(124,58,237,0.25);
    }

    .pw-title {
      font-size: 1.25rem;
      font-weight: 700;
      color: #18181b;
      margin-bottom: .5rem;
    }

    .pw-desc {
      font-size: .875rem;
      color: #71717a;
      line-height: 1.6;
      margin-bottom: 2rem;
    }

    /* Form */
    .pw-form { display: flex; flex-direction: column; gap: .75rem; }

    .pw-input-wrap { position: relative; }
    .pw-input {
      width: 100%;
      padding: .85rem 1.25rem;
      border: 1.5px solid #e4e4e7;
      border-radius: .875rem;
      font-size: .9rem;
      font-family: inherit;
      outline: none;
      transition: border-color .2s;
      background: #fafafa;
      color: #18181b;
      text-align: center;
      letter-spacing: .1em;
    }
    .pw-input:focus { border-color: #7c3aed; background: #fff; }
    .pw-input::placeholder { letter-spacing: 0; color: #a1a1aa; }

    .pw-btn {
      padding: .9rem;
      background: linear-gradient(135deg, #7c3aed, #fe7e41);
      color: #fff;
      border: none;
      border-radius: 9999px;
      font-size: .9rem;
      font-weight: 700;
      font-family: inherit;
      cursor: pointer;
      transition: filter .2s, transform .15s;
      letter-spacing: .03em;
    }
    .pw-btn:hover { filter: brightness(1.08); transform: translateY(-1px); }
    .pw-btn:active { transform: translateY(0); }

    .pw-error {
      color: #ef4444;
      font-size: .8rem;
      background: #fef2f2;
      border-radius: .5rem;
      padding: .5rem .75rem;
    }

    .pw-footer {
      margin-top: 2rem;
      font-size: .75rem;
      color: #a1a1aa;
    }
    .pw-footer a { color: #7c3aed; text-decoration: none; }
    .pw-footer a:hover { text-decoration: underline; }

    /* Redes sociais */
    .pw-social {
      display: flex;
      justify-content: center;
      gap: .75rem;
      margin-top: 1.5rem;
    }
    .pw-social-btn {
      width: 44px;
      height: 44px;
      border-radius: 9999px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.1rem;
      color: #fff;
      text-decoration: none;
      transition: transform .2s, filter .2s, box-shadow .2s;
      box-shadow: 0 4px 12px rgba(0,0,0,.15);
    }
    .pw-social-btn:hover { transform: translateY(-3px); filter: brightness(1.1); box-shadow: 0 8px 20px rgba(0,0,0,.2); }
    .pw-social-btn.instagram { background: radial-gradient(circle at 30% 107%, #fdf497 0%, #fdf497 5%, #fd5949 45%, #d6249f 60%, #285AEB 90%); }
    .pw-social-btn.whatsapp  { background: #25D366; }
    .pw-social-btn.tiktok    { background: #010101; }
    .pw-social-btn.facebook  { background: #1877F2; }

    /* Contato */
    .pw-contact {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: .4rem;
      margin-top: 1rem;
      font-size: .8rem;
      color: #71717a;
    }
    .pw-contact a { color: #25D366; font-weight: 600; text-decoration: none; }
    .pw-contact a:hover { text-decoration: underline; }

    /* Decoração de fundo */
    .pw-blob {
      position: fixed;
      border-radius: 9999px;
      filter: blur(80px);
      opacity: .18;
      z-index: 0;
      pointer-events: none;
    }
    .pw-blob-1 { width: 400px; height: 400px; background: #7c3aed; top: -100px; left: -100px; }
    .pw-blob-2 { width: 350px; height: 350px; background: #fe7e41; bottom: -80px; right: -80px; }
  </style>
</head>
<body>
  <div class="pw-blob pw-blob-1"></div>
  <div class="pw-blob pw-blob-2"></div>

  <div class="pw-card">
    <p class="pw-brand">{{ shop.name | upcase }}</p>
    <p class="pw-tagline">Muito além do básico</p>

    <div class="pw-icon">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round">
        <rect x="3" y="11" width="18" height="11" rx="2"/>
        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
      </svg>
    </div>

    <h1 class="pw-title">Loja em preparação ✨</h1>
    <p class="pw-desc">Estamos preparando algo incrível para você.<br>Em breve nossa loja estará no ar!</p>

    {{ form 'storefront_password' }}
      <div class="pw-form">
        {% if form.errors %}
          <p class="pw-error">Senha incorreta. Tente novamente.</p>
        {% endif %}
        <input class="pw-input" type="password" name="password" placeholder="Digite a senha de acesso" autofocus>
        <button class="pw-btn" type="submit">Entrar na loja →</button>
      </div>
    {{ endform }}

    <!-- Redes Sociais -->
    <div class="pw-social">
      <a href="https://www.instagram.com/musasclubfit" target="_blank" class="pw-social-btn instagram" title="Instagram">
        <i class="fa-brands fa-instagram"></i>
      </a>
      <a href="https://wa.me/5562994319090" target="_blank" class="pw-social-btn whatsapp" title="WhatsApp">
        <i class="fa-brands fa-whatsapp"></i>
      </a>
      <a href="https://musasclub.com.br" target="_blank" class="pw-social-btn tiktok" title="TikTok">
        <i class="fa-brands fa-tiktok"></i>
      </a>
    </div>

    <div class="pw-footer">
      <a href="/admin">Sou o proprietário</a> &nbsp;·&nbsp;
      Powered by Shopify
    </div>
  </div>
  {{ content_for_layout }}
</body>
</html>
