{% if settings.popup_enabled %}

<style>
  @keyframes popupSlideIn {
    from { transform: translateX(-120%); opacity: 0; }
    to   { transform: translateX(0);     opacity: 1; }
  }
  @keyframes popupSlideOut {
    from { transform: translateX(0);     opacity: 1; }
    to   { transform: translateX(-120%); opacity: 0; }
  }
  #promo-popup {
    position: fixed;
    left: 1.5rem;
    top: 50%;
    transform: translateY(-50%) translateX(-120%);
    z-index: 9999;
    max-width: 340px;
    width: calc(100% - 3rem);
    opacity: 0;
    pointer-events: none;
  }
  #promo-popup.pp-show {
    animation: popupSlideIn 0.45s cubic-bezier(0.34,1.56,0.64,1) forwards;
    pointer-events: all;
  }
  #promo-popup.pp-hide {
    animation: popupSlideOut 0.35s ease-in forwards;
    pointer-events: none;
  }
  #promo-popup-inner {
    background: #fff;
    border-radius: 1.25rem;
    padding: 1.5rem;
    box-shadow: 0 8px 40px rgba(0,0,0,0.18);
    position: relative;
    overflow: hidden;
  }
  #promo-popup-inner::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(113,68,155,0.06) 0%, rgba(254,126,65,0.06) 100%);
    pointer-events: none;
  }
  #promo-popup .pp-close {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    background: rgba(0,0,0,0.06);
    border: none;
    border-radius: 50%;
    width: 28px;
    height: 28px;
    cursor: pointer;
    font-size: 1.1rem;
    color: #52525b;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
    transition: background 0.2s;
  }
  #promo-popup .pp-close:hover { background: rgba(0,0,0,0.12); }
  #promo-popup .pp-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: rgba(113,68,155,0.1);
    border-radius: 9999px;
    padding: 0.3rem 0.75rem;
    margin-bottom: 0.85rem;
  }
  #promo-popup .pp-badge-text {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #71449b;
  }
  #promo-popup .pp-title {
    font-size: 1rem;
    font-weight: 700;
    color: #18181b;
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }
  #promo-popup .pp-text {
    font-size: 0.875rem;
    color: #52525b;
    line-height: 1.55;
    margin-bottom: 1rem;
  }
  #promo-popup .pp-btn {
    display: block;
    text-align: center;
    background: linear-gradient(135deg, #71449b, #fe7e41);
    color: #fff;
    font-weight: 600;
    font-size: 0.875rem;
    padding: 0.75rem 1rem;
    border-radius: 9999px;
    text-decoration: none;
    transition: opacity 0.2s;
  }
  #promo-popup .pp-btn:hover { opacity: 0.88; }
</style>

<div id="promo-popup">
  <div id="promo-popup-inner">
    <button class="pp-close" onclick="ppClose()" aria-label="Fechar">×</button>

    <div class="pp-badge">
      <span>{{ settings.popup_icon | default: '🎁' }}</span>
      <span class="pp-badge-text">{{ settings.popup_badge | default: 'Oferta Especial' }}</span>
    </div>

    {% if settings.popup_title != blank %}
      <p class="pp-title">{{ settings.popup_title }}</p>
    {% endif %}

    {% if settings.popup_text != blank %}
      <p class="pp-text">{{ settings.popup_text }}</p>
    {% endif %}

    {% if settings.popup_btn_label != blank %}
      <a href="{{ settings.popup_btn_url | default: '#' }}" class="pp-btn">
        {{ settings.popup_btn_label }}
      </a>
    {% endif %}
  </div>
</div>

<script>
(function(){
  var showDelay  = {{ settings.popup_delay   | default: 3 }} * 1000;
  var hideAfter  = {{ settings.popup_hide_after | default: 8 }} * 1000;
  var KEY = '_pp_{{ settings.popup_title | md5 | slice: 0, 6 }}';
  var el  = document.getElementById('promo-popup');
  var hideTimer;

  if(sessionStorage.getItem(KEY)) return;

  function ppShow(){
    el.classList.remove('pp-hide');
    el.classList.add('pp-show');
    hideTimer = setTimeout(ppAutoHide, hideAfter);
  }

  function ppAutoHide(){
    el.classList.remove('pp-show');
    el.classList.add('pp-hide');
    sessionStorage.setItem(KEY, '1');
  }

  window.ppClose = function(){
    clearTimeout(hideTimer);
    ppAutoHide();
  };

  setTimeout(ppShow, showDelay);
})();
</script>

{% endif %}
