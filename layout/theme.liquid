<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#fe7e41">
  <title>{{ page_title }} - {{ shop.name }}</title>
  <meta name="description" content="{{ page_description | escape }}">

  {{ content_for_header }}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Merriweather:wght@300;400;700&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  {{ 'theme.css' | asset_url | stylesheet_tag }}
</head>
<body>
  {% section 'announcement-bar' %}
  {% section 'header' %}

  <main id="main-content" style="padding-top:17px;">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  <!-- Cart Drawer -->
  {% render 'cart-drawer' %}

  <!-- Cookie Banner -->
  {% render 'cookie-banner' %}

  {{ 'theme.js' | asset_url | script_tag }}
</body>
</html>
