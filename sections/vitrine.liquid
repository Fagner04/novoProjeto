{% assign vitrine_collection = collections[section.settings.collection] %}
{% assign ver_todos_url = section.settings.ver_todos_link | default: vitrine_collection.url | default: '/collections/all' %}

<section class="vitrine-section" style="padding:{{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;background:{{ section.settings.bg_color | default: '#fafafa' }};">
  <div class="container-elegant">

    <div class="vitrine-header">
      <h2 class="vitrine-title">{{ section.settings.title | default: 'VITRINE' }}</h2>
      {% if ver_todos_url != blank %}
        <a href="{{ ver_todos_url }}" class="vitrine-ver-todos">Ver Todos</a>
      {% endif %}
    </div>

    <div class="vitrine-grid">
      {% if vitrine_collection != blank %}
        {% for product in vitrine_collection.products limit: section.settings.products_count %}
          <a href="{{ product.url }}" class="vitrine-card">
            <div class="vitrine-card-img">
              {% if product.featured_image %}
                <img src="{{ product.featured_image | image_url: width: 200 }}" alt="{{ product.featured_image.alt | escape }}" loading="lazy" width="200" height="200">
              {% else %}
                <div class="vitrine-card-no-img">
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                </div>
              {% endif %}
              {% unless product.available %}
                <span class="vitrine-badge-esgotado">Esgotado</span>
              {% endunless %}
            </div>
            <div class="vitrine-card-info">
              <p class="vitrine-card-name">{{ product.title | upcase }}</p>
              <p class="vitrine-card-price">R$ {{ product.price_min | money_without_currency }}</p>
              {% if section.settings.show_frete %}
                <p class="vitrine-card-frete">Frete Grátis ⚡</p>
              {% endif %}
              {% if section.settings.show_parcelas %}
                <p class="vitrine-card-parcelas">6x de R$ {{ product.price_min | divided_by: 6 | money_without_currency }} <span>sem juros</span></p>
              {% endif %}
              <p class="vitrine-card-status">
                <span class="vitrine-dot {% unless product.available %}vitrine-dot-off{% endunless %}"></span>
                {% if product.available %}Disponível{% else %}Esgotado{% endif %}
              </p>
            </div>
          </a>
        {% endfor %}
      {% else %}
        <p style="color:#aaa;font-size:.875rem;">Selecione uma coleção nas configurações da seção.</p>
      {% endif %}
    </div>

  </div>
</section>

<style>
.vitrine-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:1.25rem; }
.vitrine-title { font-size:1rem; font-weight:700; letter-spacing:.08em; text-transform:uppercase; position:relative; padding-bottom:.35rem; }
.vitrine-title::after { content:''; position:absolute; bottom:0; left:0; width:2.5rem; height:2px; background:{{ section.settings.accent_color | default: '#fe7e41' }}; border-radius:2px; }
.vitrine-ver-todos { font-size:.875rem; font-weight:600; color:{{ section.settings.accent_color | default: '#fe7e41' }}; text-decoration:none; }
.vitrine-ver-todos:hover { text-decoration:underline; }

.vitrine-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1rem; }
@media(max-width:900px){ .vitrine-grid { grid-template-columns:repeat(2,1fr); } }
@media(max-width:540px){ .vitrine-grid { grid-template-columns:1fr; } }

.vitrine-card { display:flex; align-items:center; gap:.875rem; background:#fff; border-radius:1rem; padding:.75rem; text-decoration:none; color:inherit; box-shadow:0 2px 12px rgba(0,0,0,.06); transition:box-shadow .2s,transform .2s; }
.vitrine-card:hover { box-shadow:0 6px 24px rgba(0,0,0,.11); transform:translateY(-2px); }

.vitrine-card-img { width:80px; height:80px; border-radius:.75rem; overflow:hidden; flex-shrink:0; background:#f4f4f5; position:relative; }
.vitrine-card-img img { width:100%; height:100%; object-fit:cover; }
.vitrine-card-no-img { width:100%; height:100%; display:flex; align-items:center; justify-content:center; }
.vitrine-badge-esgotado { position:absolute; top:4px; left:4px; background:rgba(0,0,0,.55); color:#fff; font-size:.6rem; font-weight:700; padding:2px 5px; border-radius:4px; }

.vitrine-card-info { flex:1; min-width:0; }
.vitrine-card-name { font-size:.75rem; font-weight:700; color:#18181b; margin:0 0 2px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.vitrine-card-price { font-size:.9rem; font-weight:700; color:{{ section.settings.accent_color | default: '#fe7e41' }}; margin:0 0 2px; }
.vitrine-card-frete { font-size:.7rem; color:#16a34a; font-weight:600; margin:0 0 2px; }
.vitrine-card-parcelas { font-size:.68rem; font-weight:700; color:#18181b; margin:0 0 4px; text-transform:uppercase; letter-spacing:.03em; }
.vitrine-card-parcelas span { font-weight:400; }
.vitrine-card-status { font-size:.7rem; color:#71717a; margin:0; display:flex; align-items:center; gap:.3rem; }
.vitrine-dot { width:7px; height:7px; border-radius:9999px; background:#4ade80; flex-shrink:0; }
.vitrine-dot-off { background:#f87171; }
</style>

{% schema %}
{
  "name": "Vitrine de Produtos",
  "settings": [
    { "type": "text", "id": "title", "label": "Título da vitrine", "default": "VITRINE" },
    { "type": "collection", "id": "collection", "label": "Coleção" },
    { "type": "url", "id": "ver_todos_link", "label": "Link 'Ver Todos' (opcional)" },
    { "type": "range", "id": "products_count", "label": "Quantidade de produtos", "min": 2, "max": 24, "step": 1, "default": 6 },
    { "type": "checkbox", "id": "show_frete", "label": "Mostrar 'Frete Grátis'", "default": true },
    { "type": "checkbox", "id": "show_parcelas", "label": "Mostrar parcelamento", "default": true },
    { "type": "color", "id": "accent_color", "label": "Cor de destaque (preço, título)", "default": "#fe7e41" },
    { "type": "color", "id": "bg_color", "label": "Cor de fundo da seção", "default": "#fafafa" },
    { "type": "range", "id": "padding_top", "label": "Espaço acima (px)", "min": 0, "max": 120, "step": 4, "default": 48 },
    { "type": "range", "id": "padding_bottom", "label": "Espaço abaixo (px)", "min": 0, "max": 120, "step": 4, "default": 48 }
  ],
  "presets": [
    { "name": "Vitrine de Produtos", "category": "Produtos" }
  ]
}
{% endschema %}
