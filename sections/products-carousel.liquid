<section class="products-carousel-section">
  <div class="container-elegant">

    {% if section.settings.title != blank or section.settings.subtitle != blank %}
      <div class="section-header" style="margin-bottom:2rem;">
        {% if section.settings.label != blank %}
          <p class="label-caps" style="margin-bottom:0.5rem;">{{ section.settings.label }}</p>
        {% endif %}
        {% if section.settings.title != blank %}
          <h2 class="heading-section">{{ section.settings.title }}</h2>
        {% endif %}
        {% if section.settings.subtitle != blank %}
          <div style="display:flex;align-items:center;justify-content:center;gap:0.5rem;margin:0.75rem 0;">
            <span style="width:3rem;height:1px;background:rgba(254,126,65,0.4);display:block;"></span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="var(--brand-orange)" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <span style="width:3rem;height:1px;background:rgba(254,126,65,0.4);display:block;"></span>
          </div>
          <p class="text-elegant" style="max-width:42rem;margin:0 auto;text-align:center;">{{ section.settings.subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="carousel-tabs" id="carousel-tabs">
      <button class="carousel-tab active" onclick="filterCarousel(this,'all')">Todos</button>
      {% for block in section.blocks %}
        {% if block.settings.collection != blank %}
          <button class="carousel-tab" onclick="filterCarousel(this,'{{ block.settings.collection.handle }}')">
            {{ block.settings.label | default: block.settings.collection.title }}
          </button>
        {% endif %}
      {% endfor %}
    </div>

    <div class="carousel-wrapper" id="carousel-wrapper">
      <button class="carousel-arrow carousel-prev" onclick="slideCarousel(-1)" aria-label="Anterior">&#8592;</button>
      <div class="carousel-track-outer">
        <div class="carousel-track" id="carousel-track">

          {% comment %}Grupo Todos — usa colecao configuravel{% endcomment %}
          {% assign all_col = section.settings.all_collection %}
          <div class="cg-group" data-group="all">
            {% if all_col != blank %}
              {% for product in all_col.products limit: 20 %}
                {% render 'carousel-product-card', product: product %}
              {% endfor %}
            {% else %}
              <p style="padding:2rem;color:#888;font-size:.875rem;">Selecione uma colecao em "Colecao Todos" nas configuracoes.</p>
            {% endif %}
          </div>

          {% comment %}Grupos por aba{% endcomment %}
          {% for block in section.blocks %}
            {% if block.settings.collection != blank %}
              {% assign col = block.settings.collection %}
              <div class="cg-group" data-group="{{ col.handle }}" style="display:none;">
                {% if col.products_count > 0 %}
                  {% for product in col.products limit: 20 %}
                    {% render 'carousel-product-card', product: product %}
                  {% endfor %}
                {% else %}
                  <p style="padding:2rem;color:#888;font-size:.875rem;width:100%;text-align:center;">
                    Colecao "{{ col.title }}" sem produtos. Handle: {{ col.handle }}
                  </p>
                {% endif %}
              </div>
            {% endif %}
          {% endfor %}

        </div>
      </div>
      <button class="carousel-arrow carousel-next" onclick="slideCarousel(1)" aria-label="Proximo">&#8594;</button>
    </div>

  </div>
</section>

<script>
var carouselOffset = 0;
var currentGroup = 'all';

function getVisibleCount() {
  return window.innerWidth < 640 ? 1 : window.innerWidth < 1024 ? 2 : window.innerWidth < 1280 ? 3 : 4;
}

function getActiveGroup() {
  return document.querySelector('.cg-group[data-group="' + currentGroup + '"]');
}

function getActiveCards() {
  var g = getActiveGroup();
  return g ? Array.from(g.querySelectorAll('.carousel-card')) : [];
}

function updatePosition() {
  var cards = getActiveCards();
  if (!cards.length) return;
  var w = cards[0].offsetWidth + 16;
  var g = getActiveGroup();
  if (g) g.style.transform = 'translateX(-' + (carouselOffset * w) + 'px)';
}

function slideCarousel(dir) {
  var cards = getActiveCards();
  var max = Math.max(0, cards.length - getVisibleCount());
  carouselOffset = Math.min(Math.max(carouselOffset + dir, 0), max);
  updatePosition();
}

function filterCarousel(btn, handle) {
  document.querySelectorAll('.carousel-tab').forEach(function(t) { t.classList.remove('active'); });
  btn.classList.add('active');
  currentGroup = handle;
  carouselOffset = 0;
  document.querySelectorAll('.cg-group').forEach(function(g) {
    var show = g.dataset.group === handle;
    g.style.display = show ? 'flex' : 'none';
    if (show) g.style.transform = 'translateX(0)';
  });
  stopAutoplay(); startAutoplay();
}

window.addEventListener('resize', updatePosition);

var autoT;
function startAutoplay() {
  autoT = setInterval(function() {
    var cards = getActiveCards();
    var max = Math.max(0, cards.length - getVisibleCount());
    carouselOffset = carouselOffset >= max ? 0 : carouselOffset + 1;
    updatePosition();
  }, 3000);
}
function stopAutoplay() { clearInterval(autoT); }

startAutoplay();
var wr = document.getElementById('carousel-wrapper');
if (wr) {
  wr.addEventListener('mouseenter', stopAutoplay);
  wr.addEventListener('mouseleave', startAutoplay);
}
</script>

{% schema %}
{
  "name": "Carrossel de Produtos",
  "blocks": [
    {
      "type": "category",
      "name": "Categoria",
      "settings": [
        { "type": "text", "id": "label", "label": "Nome da aba", "default": "Categoria" },
        { "type": "collection", "id": "collection", "label": "Colecao" }
      ]
    }
  ],
  "settings": [
    { "type": "collection", "id": "all_collection", "label": "Colecao para aba Todos" },
    { "type": "text", "id": "label", "label": "Label acima do titulo", "default": "DESTAQUES" },
    { "type": "text", "id": "title", "label": "Titulo da secao", "default": "A Colecao" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitulo", "default": "Com cores intensas, cheias de personalidade, e modelos inovadores que valorizam o corpo real." }
  ],
  "presets": [
    {
      "name": "Carrossel de Produtos",
      "blocks": [
        { "type": "category", "settings": { "label": "Conjuntos" } },
        { "type": "category", "settings": { "label": "Macacoes" } }
      ]
    }
  ]
}
{% endschema %}
