<div class="product-page">
  <div class="container-elegant">

    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:2rem;">
      <h1 class="heading-section">Olá, {{ customer.first_name }}</h1>
      <a href="{{ routes.account_logout_url }}" style="font-size:0.875rem;color:var(--muted-foreground);">Sair</a>
    </div>

    <h2 style="font-family:'Merriweather',serif;font-size:1.25rem;margin-bottom:1.5rem;">Meus Pedidos</h2>

    {% if customer.orders.size > 0 %}
      <div style="display:flex;flex-direction:column;gap:1rem;">
        {% for order in customer.orders %}
          <div style="border:1px solid var(--border);border-radius:0.75rem;padding:1.25rem;">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:0.75rem;">
              <div>
                <p style="font-weight:600;font-size:0.875rem;">Pedido {{ order.name }}</p>
                <p style="font-size:0.75rem;color:var(--muted-foreground);">{{ order.created_at | date: '%d/%m/%Y' }}</p>
              </div>
              <span style="font-size:0.75rem;padding:0.25rem 0.75rem;border-radius:9999px;background:rgba(254,126,65,0.15);color:var(--brand-orange);font-weight:600;">
                {{ order.financial_status_label }}
              </span>
            </div>
            <p style="font-size:0.875rem;font-weight:600;">{{ order.total_price | money }}</p>
            <a href="{{ order.customer_url }}" style="font-size:0.8125rem;color:var(--brand-orange);margin-top:0.5rem;display:inline-block;">
              Ver detalhes →
            </a>
          </div>
        {% endfor %}
      </div>
    {% else %}
      <div style="text-align:center;padding:3rem 0;color:var(--muted-foreground);">
        <p>Você ainda não fez nenhum pedido.</p>
        <a href="/collections/all" class="btn-primary btn-musas" style="border-radius:9999px;margin-top:1.5rem;display:inline-flex;">
          Começar a comprar
        </a>
      </div>
    {% endif %}

  </div>
</div>
