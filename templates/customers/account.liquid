<div class="acc-page">
  <div class="container-elegant">

    <!-- Top bar -->
    <div class="acc-topbar">
      <div class="acc-avatar">{{ customer.first_name | slice: 0 | upcase }}</div>
      <div class="acc-topbar-info">
        <h1>Olá, {{ customer.first_name }} 👋</h1>
        <p>{{ customer.email }}</p>
      </div>
      <a href="{{ routes.account_logout_url }}" class="acc-logout">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        Sair
      </a>
    </div>

    <!-- Stats -->
    <div class="acc-stats">
      <div class="acc-stat">
        <span class="acc-stat-icon">🛍️</span>
        <div>
          <strong>{{ customer.orders.size }}</strong>
          <small>Pedidos</small>
        </div>
      </div>
      <div class="acc-stat">
        <span class="acc-stat-icon">📍</span>
        <div>
          <strong>{{ customer.addresses.size }}</strong>
          <small>Endereços</small>
        </div>
      </div>
      <div class="acc-stat">
        <span class="acc-stat-icon">💜</span>
        <div>
          <strong>Musas</strong>
          <small>Membro</small>
        </div>
      </div>
    </div>

    <!-- Tabs -->
    <div class="acc-tabs">
      <button class="acc-tab active" onclick="accTab(this,'orders')">Meus Pedidos</button>
      <button class="acc-tab" onclick="accTab(this,'address')">Endereços</button>
      <button class="acc-tab" onclick="accTab(this,'profile')">Meu Perfil</button>
    </div>

    <!-- Orders -->
    <div class="acc-panel" id="acc-orders">
      {% if customer.orders.size > 0 %}
        <div class="acc-orders-list">
          {% for order in customer.orders %}
            <div class="acc-order-card">
              <div class="acc-order-top">
                <div>
                  <p class="acc-order-num">{{ order.name }}</p>
                  <p class="acc-order-date">{{ order.created_at | date: '%d de %B de %Y' }}</p>
                </div>
                <span class="acc-order-badge {% if order.financial_status == 'paid' %}badge-paid{% elsif order.financial_status == 'pending' %}badge-pending{% else %}badge-other{% endif %}">
                  {{ order.financial_status_label }}
                </span>
              </div>
              <div class="acc-order-items">
                {% for item in order.line_items limit: 3 %}
                  <div class="acc-order-item">
                    {% if item.image %}
                      <img src="{{ item.image | image_url: width: 80 }}" alt="{{ item.title }}" width="40" height="40">
                    {% else %}
                      <div class="acc-order-item-placeholder">👗</div>
                    {% endif %}
                    <span>{{ item.title | truncate: 30 }}</span>
                    <span class="acc-order-item-qty">x{{ item.quantity }}</span>
                  </div>
                {% endfor %}
                {% if order.line_items.size > 3 %}
                  <p class="acc-order-more">+{{ order.line_items.size | minus: 3 }} itens</p>
                {% endif %}
              </div>
              <div class="acc-order-footer">
                <strong>{{ order.total_price | money }}</strong>
                <a href="{{ order.customer_url }}" class="acc-order-link">Ver detalhes →</a>
              </div>
            </div>
          {% endfor %}
        </div>
      {% else %}
        <div class="acc-empty">
          <div class="acc-empty-icon">🛍️</div>
          <h3>Nenhum pedido ainda</h3>
          <p>Que tal explorar nossa coleção?</p>
          <a href="/collections/all" class="auth-btn" style="display:inline-flex;width:auto;padding:.75rem 2rem;">Ver produtos</a>
        </div>
      {% endif %}
    </div>

    <!-- Addresses -->
    <div class="acc-panel" id="acc-address" style="display:none;">
      {% if customer.addresses.size > 0 %}
        <div class="acc-addr-grid">
          {% for address in customer.addresses %}
            <div class="acc-addr-card {% if address == customer.default_address %}acc-addr-default{% endif %}">
              {% if address == customer.default_address %}
                <span class="acc-addr-badge">Principal</span>
              {% endif %}
              <p class="acc-addr-name">{{ address.first_name }} {{ address.last_name }}</p>
              <p>{{ address.address1 }}</p>
              {% if address.address2 != blank %}<p>{{ address.address2 }}</p>{% endif %}
              <p>{{ address.city }}, {{ address.province }} - {{ address.zip }}</p>
              <p>{{ address.country }}</p>
              <div class="acc-addr-actions">
                <a href="{{ routes.account_addresses_url }}/{{ address.id }}/edit">Editar</a>
                <a href="{{ routes.account_addresses_url }}/{{ address.id }}" data-method="delete" style="color:#ef4444;">Remover</a>
              </div>
            </div>
          {% endfor %}
        </div>
      {% else %}
        <div class="acc-empty">
          <div class="acc-empty-icon">📍</div>
          <h3>Nenhum endereço salvo</h3>
          <p>Adicione um endereço para agilizar suas compras</p>
        </div>
      {% endif %}
      <a href="{{ routes.account_addresses_url }}" class="acc-add-addr">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Adicionar endereço
      </a>
    </div>

    <!-- Profile -->
    <div class="acc-panel" id="acc-profile" style="display:none;">
      <div class="acc-profile-card">
        <div class="acc-profile-avatar">{{ customer.first_name | slice: 0 | upcase }}{{ customer.last_name | slice: 0 | upcase }}</div>
        <div class="acc-profile-info">
          <h3>{{ customer.first_name }} {{ customer.last_name }}</h3>
          <p>{{ customer.email }}</p>
          {% if customer.phone != blank %}<p>{{ customer.phone }}</p>{% endif %}
        </div>
      </div>
      <div class="acc-profile-actions">
        <a href="{{ routes.account_url }}" class="acc-profile-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          Editar dados
        </a>
        <a href="{{ routes.account_recover_url }}" class="acc-profile-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          Alterar senha
        </a>
      </div>
    </div>

  </div>
</div>

<script>
function accTab(btn, panel) {
  document.querySelectorAll('.acc-tab').forEach(function(t){ t.classList.remove('active'); });
  document.querySelectorAll('.acc-panel').forEach(function(p){ p.style.display='none'; });
  btn.classList.add('active');
  document.getElementById('acc-'+panel).style.display='block';
}
</script>
