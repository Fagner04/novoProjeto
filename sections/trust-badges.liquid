<section class="trust-section">
  <div class="container-elegant">
    <div class="trust-grid" style="grid-template-columns: repeat(2, 1fr);">
      {% for block in section.blocks %}
        <div class="trust-item" {{ block.shopify_attributes }}>
          <div class="trust-icon">            {% if block.settings.icon == 'shield' %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            {% elsif block.settings.icon == 'truck' %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 3h15v13H1z"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            {% elsif block.settings.icon == 'chat' %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            {% elsif block.settings.icon == 'refresh' %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.51"/></svg>
            {% elsif block.settings.icon == 'star' %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            {% elsif block.settings.icon == 'heart' %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            {% elsif block.settings.icon == 'lock' %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            {% else %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
            {% endif %}
          </div>
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.text }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Selos de Confiança",
  "blocks": [
    {
      "type": "badge",
      "name": "Selo",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Ícone",
          "options": [
            { "value": "shield", "label": "Escudo" },
            { "value": "truck", "label": "Caminhão" },
            { "value": "chat", "label": "Chat" },
            { "value": "refresh", "label": "Troca" },
            { "value": "star", "label": "Estrela" },
            { "value": "heart", "label": "Coração" },
            { "value": "lock", "label": "Cadeado" },
            { "value": "screen", "label": "Tela" }
          ],
          "default": "shield"
        },
        { "type": "text", "id": "title", "label": "Título", "default": "Título do selo" },
        { "type": "text", "id": "text", "label": "Descrição", "default": "Descrição do selo" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Selos de Confiança",
      "blocks": [
        { "type": "badge", "settings": { "icon": "screen", "title": "Compra Segura", "text": "Ambiente seguro para pagamentos online" } },
        { "type": "badge", "settings": { "icon": "truck", "title": "Entrega Rápida", "text": "Envio rápido e acompanhado com código de rastreio" } },
        { "type": "badge", "settings": { "icon": "chat", "title": "Suporte Profissional", "text": "Equipe de suporte de extrema qualidade a semana toda" } },
        { "type": "badge", "settings": { "icon": "shield", "title": "Satisfação ou Reembolso", "text": "Caso haja algo, devolvemos seu dinheiro" } },
        { "type": "badge", "settings": { "icon": "refresh", "title": "Primeira Troca Grátis", "text": "Troque sem custo na sua primeira compra" } }
      ]
    }
  ]
}
{% endschema %}
