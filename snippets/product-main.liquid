<script>
  var FRETE_API = {{ settings.frete_planilha_url | json }};

  function freteFormatCep(input) {
    var v = input.value.replace(/\D/g, '').slice(0, 8);
    input.value = v.length > 5 ? v.slice(0,5) + '-' + v.slice(5) : v;
    if (v.length === 8) calcularFrete();
  }

  function calcularFrete() {
    var cepRaw = (document.getElementById('frete-cep').value || '').replace(/\D/g, '');
    var endDiv = document.getElementById('frete-endereco');
    var resDiv = document.getElementById('frete-resultado');
    if (cepRaw.length !== 8) {
      endDiv.innerHTML = '';
      resDiv.innerHTML = '<p class="frete-erro">Digite um CEP válido com 8 dígitos.</p>';
      return;
    }
    if (!FRETE_API) {
      resDiv.innerHTML = '<p class="frete-erro">URL da planilha não configurada nas settings.</p>';
      return;
    }
    resDiv.innerHTML = '<p class="frete-loading"><span class="frete-spinner"></span> Consultando...</p>';
    endDiv.innerHTML = '';

    fetch('https://viacep.com.br/ws/' + cepRaw + '/json/')
      .then(function(r){ return r.json(); })
      .then(function(viaData) {
        if (viaData.erro) { resDiv.innerHTML = '<p class="frete-erro">CEP não encontrado.</p>'; return; }
        endDiv.innerHTML = '<p class="frete-end-text"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg> '
          + (viaData.logradouro ? viaData.logradouro + ', ' : '') + viaData.bairro + ' — ' + viaData.localidade + '/' + viaData.uf + '</p>';

        fetch(FRETE_API + '?cep=' + cepRaw)
          .then(function(r){ return r.json(); })
          .then(function(data) {
            if (!data) { resDiv.innerHTML = '<p class="frete-erro">Resposta inválida da planilha.</p>'; return; }
            renderFrete(data);
          })
          .catch(function() {
            resDiv.innerHTML = '<p class="frete-erro">Não foi possível consultar o frete. Tente novamente.</p>';
          });
      })
      .catch(function() {
        resDiv.innerHTML = '<p class="frete-erro">Erro ao consultar CEP. Tente novamente.</p>';
      });
  }

  function renderFrete(data) {
    var resDiv = document.getElementById('frete-resultado');
    if (!data) { resDiv.innerHTML = '<p class="frete-erro">Sem resultado.</p>'; return; }

    // Formato: { success: false, error: "..." }
    if (!data.success && data.error) {
      resDiv.innerHTML = '<p class="frete-erro">' + data.error + '</p>';
      return;
    }

    var html = '<div class="frete-opcoes">';

    // Formato: { options: [{name, price, estimated_days}] }
    if (data.options && data.options.length > 0) {
      data.options.forEach(function(op) {
        var price = typeof op.price === 'number' ? op.price.toFixed(2).replace('.', ',') : op.price;
        var gratis = !op.price || op.price == 0;
        html += '<div class="frete-opcao">'
          + '<div class="frete-opcao-info">'
          + '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 3h15v13H1z"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>'
          + '<div><strong>' + (op.name || 'Entrega') + '</strong>'
          + (op.estimated_days ? '<span class="frete-prazo">' + op.estimated_days + '</span>' : '')
          + '</div></div>'
          + '<span class="frete-valor ' + (gratis ? 'frete-gratis' : '') + '">' + (gratis ? 'GRÁTIS' : 'R$ ' + price) + '</span>'
          + '</div>';
      });
    // Formato legado: { frete, prazo }
    } else if (data.frete !== undefined) {
      var valor = typeof data.frete === 'number' ? data.frete.toFixed(2).replace('.', ',') : data.frete;
      var gratis = !data.frete || data.frete == 0;
      html += '<div class="frete-opcao">'
        + '<div class="frete-opcao-info">'
        + '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 3h15v13H1z"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>'
        + '<div><strong>Entrega</strong>'
        + (data.prazo ? '<span class="frete-prazo">Até ' + data.prazo + ' dias úteis</span>' : '')
        + '</div></div>'
        + '<span class="frete-valor ' + (gratis ? 'frete-gratis' : '') + '">' + (gratis ? 'GRÁTIS' : 'R$ ' + valor) + '</span>'
        + '</div>';
    } else {
      resDiv.innerHTML = '<p class="frete-erro">Formato de resposta não reconhecido.</p>';
      return;
    }

    html += '</div>';
    resDiv.innerHTML = html;
  }
</script>

<div class="product-page">
  <div class="container-elegant">

    <a href="{{ collection.url | default: '/collections/all' }}" class="product-back-link">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      Voltar
    </a>

    <div class="product-layout-new">

      <!-- LEFT: Thumbnails vertical -->
      <div class="product-thumbs-col" id="thumbs-col">
        <button class="thumbs-scroll-btn" onclick="scrollThumbs(-1)" aria-label="Subir">&#8963;</button>
        <div class="thumbs-list" id="thumbs-list">
          {% for image in product.images %}
            <img
              src="{{ image | image_url: width: 200 }}"
              alt="{{ image.alt | escape }}"
              class="thumb-item {% if forloop.first %}active{% endif %}"
              onclick="setMainImages({{ forloop.index0 }})"
              loading="lazy" width="200" height="267">
          {% endfor %}
        </div>
        <button class="thumbs-scroll-btn" onclick="scrollThumbs(1)" aria-label="Descer">&#8964;</button>
      </div>

      <!-- CENTER: 2 main images side by side -->
      <div class="product-main-images">
        <div class="main-images-grid" id="main-images-grid">
          {% for image in product.images limit: 2 %}
            <div class="main-image-slot {% if forloop.first %}has-badge{% endif %}">
              {% if forloop.first %}
                <span class="product-new-badge">Novidade</span>
              {% endif %}
              <img
                src="{{ image | image_url: width: 900 }}"
                alt="{{ image.alt | escape }}"
                id="main-img-{{ forloop.index0 }}"
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                width="900" height="1200">
            </div>
          {% endfor %}
        </div>

        <!-- Thumbnails horizontais mobile -->
        <div class="mobile-thumbs" id="mobile-thumbs">
          {% for image in product.images %}
            <img
              src="{{ image | image_url: width: 200 }}"
              alt="{{ image.alt | escape }}"
              class="thumb-item {% if forloop.first %}active{% endif %}"
              onclick="setMainImages({{ forloop.index0 }})"
              loading="lazy" width="200" height="267">
          {% endfor %}
        </div>

        <!-- Description box below images -->
        <div class="product-desc-box">
          <h4>📋 DESCRIÇÃO DO PRODUTO</h4>
          <p class="desc-size-guide">🏷️ Guia de Medidas</p>
          <div class="product-desc-content" id="desc-content">
            {{ product.description }}
          </div>
          <button class="desc-toggle-btn" id="desc-toggle" onclick="toggleDesc()">+ Ver mais</button>
        </div>
      </div>

      <!-- RIGHT: Product info -->
      <div class="product-info-col">
        {% if product.vendor != blank %}
          <p class="label-caps" style="margin-bottom:0.5rem;">{{ product.vendor }}</p>
        {% endif %}

        <div style="display:flex;align-items:center;justify-content:space-between;gap:1rem;">
          <h1 class="product-info-title" style="margin:0;">{{ product.title }}</h1>
          <button
            class="carousel-fav product-fav-btn"
            aria-label="Favoritar"
            data-handle="{{ product.handle }}"
            onclick="toggleFav(this,'{{ product.handle }}')"
            style="flex-shrink:0;width:2.5rem;height:2.5rem;border-radius:9999px;border:1.5px solid var(--border);background:#fff;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:border-color .2s;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
          </button>
        </div>

        <!-- Prices -->
        <div class="product-prices-block">
          <div class="price-pix-row">
            {% render 'pix-icon' %}
            <span class="price-pix-value" id="price-pix">{{ product.selected_or_first_available_variant.price | times: 0.95 | money }}</span>
            <span class="pix-badge">5%</span>
          </div>
          <div class="price-card-row">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#888" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
            <span class="price-card-value" id="price-card">{{ product.selected_or_first_available_variant.price | money }}</span>
            <span class="avista-badge">À VISTA</span>
          </div>
          <p class="price-installments" id="price-installments">ou 6x de {{ product.selected_or_first_available_variant.price | divided_by: 6 | money }} sem juros</p>
          {%- if product.metafields.custom.wholesale_price -%}
          <div class="wholesale-info" style="margin:8px 0 0;padding:8px 12px;background:#FFF7ED;border-radius:8px;border-left:3px solid #F97316;">
            <span style="color:#9A3412;font-weight:600;font-size:12px;">Atacado: </span>
            <strong style="color:#C2410C;font-size:14px;">{{ product.metafields.custom.wholesale_price.value | money }}</strong>
            {%- if product.metafields.custom.wholesale_min_qty -%}
            <span style="color:#9A3412;font-size:12px;"> (mín. {{ product.metafields.custom.wholesale_min_qty.value }} un.)</span>
            {%- endif -%}
            {%- if product.metafields.custom.wholesale_min_value -%}
            <br><span style="font-size:11px;color:#B45309;">Pedido mínimo: {{ product.metafields.custom.wholesale_min_value.value | money }}</span>
            {%- endif -%}
          </div>
          {%- endif -%}
        </div>

        <form action="/cart/add" method="post" id="product-form">
          <input type="hidden" name="id" id="variant-id" value="{{ product.selected_or_first_available_variant.id }}">

          <!-- Options -->
          {% for option in product.options_with_values %}
            <div class="product-options">
              <label>{{ option.name }}: <strong id="selected-{{ option.name | handleize }}">{{ option.selected_value }}</strong></label>
              <div class="option-buttons">
                {% for value in option.values %}
                  <button type="button"
                    class="option-btn {% if option.selected_value == value %}active{% endif %}"
                    data-option-index="{{ forloop.parentloop.index0 }}"
                    data-option-value="{{ value }}"
                    onclick="selectOption(this, '{{ option.name | handleize }}')">
                    {{ value }}
                  </button>
                {% endfor %}
              </div>
            </div>
          {% endfor %}

          <!-- Quantity -->
          <div class="product-qty-row">
            <div class="cart-qty">
              <button type="button" onclick="changeQty(-1)">−</button>
              <span id="qty-display">1</span>
              <button type="button" onclick="changeQty(1)">+</button>
            </div>
            <input type="hidden" name="quantity" id="qty-input" value="1">
          </div>

          <button type="submit" class="add-to-cart-btn" id="add-to-cart-btn" {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}>
            {% if product.selected_or_first_available_variant.available %}
              Adicionar ao Carrinho
            {% else %}
              Esgotado
            {% endif %}
          </button>
        </form>

        <!-- Trust mini -->
        <div class="product-trust-mini">
          <div class="trust-mini-card">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#32bcad" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <span>Compra segura</span>
          </div>
          <div class="trust-mini-card">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fe7e41" stroke-width="2"><path d="M1 3h15v13H1z"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            <span>Frete no checkout</span>
          </div>
          <div class="trust-mini-card">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="2"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.51"/></svg>
            <span>Troca fácil</span>
          </div>
          <div class="trust-mini-card">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#25D366" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
            <span>1ª Troca Grátis</span>
          </div>
        </div>

        <!-- Card de Cálculo de Frete -->
        {% if settings.frete_planilha_enabled and settings.frete_planilha_url != blank %}
        <div class="frete-card">
          <div class="frete-card-header">
            <span class="frete-card-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2"><path d="M1 3h15v13H1z"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            </span>
            <span class="frete-card-title">Calcular Frete</span>
          </div>
          <p class="frete-card-sub">Informe seu CEP para ver as opções de entrega</p>
          <div class="frete-input-row">
            <input type="text" id="frete-cep" class="frete-input" placeholder="00000-000" maxlength="9" inputmode="numeric"
              oninput="freteFormatCep(this)" onkeydown="if(event.key==='Enter')calcularFrete()">
            <button class="frete-btn" onclick="calcularFrete()" aria-label="Calcular frete">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
            </button>
          </div>
          <div id="frete-endereco" class="frete-endereco"></div>
          <div id="frete-resultado" class="frete-resultado"></div>
          <a href="https://buscacepinter.correios.com.br/app/endereco/index.php" target="_blank" class="frete-nao-sei">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
            Não sei meu CEP
          </a>
        </div>
        {% endif %}
      </div>

    </div>

    <!-- Related Products -->
    <div id="related-products-section" style="margin-top:4rem;display:none;">
      <div class="section-header">
        <p class="label-caps" style="margin-bottom:0.75rem;">Você também pode gostar</p>
        <h2 class="heading-section">Produtos Relacionados</h2>
      </div>
      <div class="products-grid" id="related-products-grid" style="margin-top:2rem;"></div>
    </div>

  </div>
</div>

<script>
  var productVariants = {{ product.variants | json }};
  var selectedOptions = [{% for option in product.options_with_values %}"{{ option.selected_value }}"{% unless forloop.last %},{% endunless %}{% endfor %}];
  var allImages = {{ product.images | map: 'src' | json }};

  // Mapa de imagem por variant_id
  var variantImages = {
    {% for variant in product.variants %}
      {% if variant.featured_image %}
        "{{ variant.id }}": "{{ variant.featured_image.src | image_url: width: 900 }}"{% unless forloop.last %},{% endunless %}
      {% endif %}
    {% endfor %}
  };

  // Mapa de estoque por variant_id (exposto via Liquid pois não vem no JSON padrão)
  var variantInventory = {
    {% for variant in product.variants %}
      "{{ variant.id }}": {
        "qty": {{ variant.inventory_quantity | default: 0 }},
        "policy": "{{ variant.inventory_policy }}",
        "management": {{ variant.inventory_management | json }}
      }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  };
  var currentPair = [0, 1];

  // --- Variant selection ---
  function selectOption(btn, optionName) {
    var index = parseInt(btn.dataset.optionIndex);
    selectedOptions[index] = btn.dataset.optionValue;
    btn.closest('.option-buttons').querySelectorAll('.option-btn').forEach(function(b) { b.classList.remove('active'); });
    btn.classList.add('active');
    document.getElementById('selected-' + optionName).textContent = btn.dataset.optionValue;

    var variant = productVariants.find(function(v) {
      return v.options.every(function(opt, i) { return opt === selectedOptions[i]; });
    });
    if (variant) {
      document.getElementById('variant-id').value = variant.id;
      var price = variant.price;
      document.getElementById('price-pix').textContent = formatMoney(Math.round(price * 0.95));
      document.getElementById('price-card').textContent = formatMoney(price);
      document.getElementById('price-installments').textContent = 'ou 6x de ' + formatMoney(Math.round(price / 6)) + ' sem juros';
      var addBtn = document.getElementById('add-to-cart-btn');
      addBtn.disabled = !variant.available;
      addBtn.textContent = variant.available ? 'Adicionar ao Carrinho' : 'Esgotado';

      // Troca imagem principal se a variante tiver imagem própria
      if (variantImages[variant.id]) {
        var img0 = document.getElementById('main-img-0');
        if (img0) img0.src = variantImages[variant.id];
        // Atualiza thumb ativo para a imagem da variante
        var varSrc = variantImages[variant.id].replace(/\?.*/, '');
        document.querySelectorAll('.thumb-item').forEach(function(t, i) {
          var tSrc = (allImages[i] || '').replace(/\?.*/, '');
          t.classList.toggle('active', tSrc === varSrc);
        });
      }
    }

    // Atualiza disponibilidade de todas as opções com base na seleção atual
    updateOptionAvailability();
    // Reseta quantidade para 1 ao trocar variante
    qty = 1;
    changeQty(0);
  }

  function updateOptionAvailability() {
    document.querySelectorAll('.option-buttons').forEach(function(group) {
      var optionIndex = null;
      group.querySelectorAll('.option-btn').forEach(function(btn) {
        if (optionIndex === null) optionIndex = parseInt(btn.dataset.optionIndex);

        // Verifica se existe variante disponível combinando este valor com as outras opções já selecionadas
        var inStock = productVariants.some(function(v) {
          return v.available && v.options.every(function(opt, i) {
            if (i === optionIndex) return opt === btn.dataset.optionValue;
            return opt === selectedOptions[i];
          });
        });

        if (!inStock) {
          btn.classList.add('unavailable');
          btn.setAttribute('title', 'Esgotado');
          btn.style.pointerEvents = ''; // mantém clicável para ver combinações
          btn.style.opacity = '0.45';
          btn.style.textDecoration = 'line-through';
        } else {
          btn.classList.remove('unavailable');
          btn.removeAttribute('title');
          btn.style.pointerEvents = '';
          btn.style.opacity = '';
          btn.style.textDecoration = '';
        }
      });
    });

    // Verifica se alguma combinação com as opções atuais está disponível
    // Se nenhuma estiver, desabilita o botão de adicionar ao carrinho
    var anyAvailable = productVariants.some(function(v) {
      return v.available && selectedOptions.every(function(sel, i) {
        return !sel || v.options[i] === sel;
      });
    });
    var addBtn = document.getElementById('add-to-cart-btn');
    if (!anyAvailable) {
      addBtn.disabled = true;
      addBtn.textContent = 'Esgotado';
    }
  }

  // Inicializa disponibilidade ao carregar
  updateOptionAvailability();

  // --- Quantity ---
  var qty = 1;

  function getMaxQty() {
    var variant = productVariants.find(function(v) {
      return v.options.every(function(opt, i) { return opt === selectedOptions[i]; });
    });
    if (!variant) return 99;
    var inv = variantInventory[variant.id];
    // Sem controle de estoque ou política "continue" = sem limite
    if (!inv || !inv.management || inv.policy === 'continue') return 99;
    // Estoque zerado ou negativo = sem limite (evita bloquear o botão)
    if (!inv.qty || inv.qty <= 0) return 99;
    return inv.qty;
  }

  function changeQty(delta) {
    var max = getMaxQty();
    qty = Math.min(max, Math.max(1, qty + delta));
    document.getElementById('qty-display').textContent = qty;
    document.getElementById('qty-input').value = qty;
    // Atualiza visual dos botões
    document.querySelector('.product-qty-row .cart-qty button:first-child').disabled = qty <= 1;
    document.querySelector('.product-qty-row .cart-qty button:last-child').disabled = qty >= max;
  }

  // Inicializa botões de quantidade após declarar tudo
  changeQty(0);

  // --- Frete: funções definidas no topo do arquivo ---

  function formatMoney(cents) {
    return 'R$\u00a0' + (cents / 100).toFixed(2).replace('.', ',');
  }

  // --- Gallery: show pair of images ---
  function setMainImages(index) {
    // Update thumbs active (desktop e mobile)
    document.querySelectorAll('.thumb-item').forEach(function(t, i) {
      t.classList.toggle('active', i === index);
    });

    var img0 = document.getElementById('main-img-0');
    var img1 = document.getElementById('main-img-1');
    if (!img0) return;

    var src0 = allImages[index] ? allImages[index].replace(/\?.*/, '') + '?width=900' : '';
    img0.src = src0;

    if (img1) {
      var nextIndex = (index + 1) < allImages.length ? index + 1 : 0;
      var src1 = allImages[nextIndex] ? allImages[nextIndex].replace(/\?.*/, '') + '?width=900' : '';
      img1.src = src1;
    }
  }

  // --- Thumbs scroll ---
  function scrollThumbs(dir) {
    var list = document.getElementById('thumbs-list');
    list.scrollBy({ top: dir * 120, behavior: 'smooth' });
  }

  // --- Description toggle ---
  function toggleDesc() {
    var content = document.getElementById('desc-content');
    var btn = document.getElementById('desc-toggle');
    var expanded = content.classList.toggle('expanded');
    btn.textContent = expanded ? '− Ver menos' : '+ Ver mais';
  }

  // --- Produtos Relacionados ---
  (function() {
    var productId = {{ product.id }};
    var collectionHandle = '{{ collection.handle | default: "all" }}';
    var currentHandle = '{{ product.handle }}';
    var section = document.getElementById('related-products-section');
    var grid = document.getElementById('related-products-grid');

    function renderCard(p, wsPrice, wsMinQty) {
      var price = p.variants && p.variants[0] ? p.variants[0].price : 0;
      var img = p.featured_image ? p.featured_image + '&width=600' : '';
      var available = p.variants && p.variants.some(function(v){ return v.available; });
      var category = p.product_type || p.vendor || '';

      var wholesaleHtml = '';
      if (wsPrice && wsPrice > 0) {
        var wsFormatted = 'R$\u00a0' + (wsPrice/100).toFixed(2).replace('.',',');
        wholesaleHtml = '<span class="wholesale-badge" style="display:inline-block;margin-top:3px;font-size:10px;color:#9A3412;line-height:1.2;font-weight:700;">Atacado: <strong style="color:#C2410C;">' + wsFormatted + '</strong>' + (wsMinQty ? ' (mín. ' + wsMinQty + ' un.)' : '') + '</span>';
      }

      return '<a href="/products/' + p.handle + '" class="product-card">'
        + '<div class="product-card-image image-hover">'
        + (img
            ? '<img src="' + img + '" alt="' + p.title.replace(/"/g,'&quot;') + '" loading="lazy" width="600" height="800">'
            : '<div style="width:100%;height:100%;background:#f2f2f3;display:flex;align-items:center;justify-content:center;font-size:.75rem;color:#aaa;">Sem imagem</div>')
        + (!available ? '<span class="product-card-badge">Esgotado</span>' : '')
        + '<div class="product-card-overlay"><span>Ver Detalhes</span></div>'
        + '</div>'
        + '<div class="product-card-info">'
        + (category ? '<p class="product-card-category">' + category + '</p>' : '')
        + '<h3 class="product-card-title">' + p.title + '</h3>'
        + '<p class="product-card-price">R$\u00a0' + (price/100).toFixed(2).replace('.',',') + '</p>'
        + wholesaleHtml
        + '</div></a>';
    }

    function fetchWholesale(handle) {
      return fetch('/products/' + handle + '?view=wholesale')
        .then(function(r){ return r.text(); })
        .then(function(text){
          var match = text.match(/\{[\s\S]*\}/);
          if (!match) return null;
          var data = JSON.parse(match[0]);
          var raw = data.wholesale_price;
          if (raw == null) return null;
          var cents = raw < 1000 ? Math.round(raw * 100) : Math.round(raw);
          return { price: cents, min_qty: data.wholesale_min_qty || null };
        })
        .catch(function(){ return null; });
    }

    function loadAndRender(products) {
      Promise.all(products.map(function(p){ return fetchWholesale(p.handle); }))
        .then(function(wsData) {
          grid.innerHTML = products.map(function(p, i){
            var ws = wsData[i];
            return renderCard(p, ws ? ws.price : null, ws ? ws.min_qty : null);
          }).join('');
          section.style.display = 'block';
        });
    }

    fetch('/recommendations/products.json?product_id=' + productId + '&limit=4')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var products = (data.products || []).filter(function(p) { return p.handle !== currentHandle; }).slice(0, 4);
        if (products.length > 0) {
          loadAndRender(products);
        } else {
          return fetch('/collections/' + collectionHandle + '/products.json?limit=8')
            .then(function(r) { return r.json(); })
            .then(function(d) {
              var ps = (d.products || []).filter(function(p) { return p.handle !== currentHandle; }).slice(0, 4);
              if (ps.length > 0) loadAndRender(ps);
            });
        }
      })
      .catch(function() {});
  })();

  // --- Verifica estoque após adicionar ao carrinho ---
  function checkStockAfterAdd(variantId, inventoryQty, inventoryPolicy, btn) {
    if (!inventoryQty || inventoryPolicy === 'continue') {
      if (btn) { btn.disabled = false; btn.textContent = 'Adicionar ao Carrinho'; }
      return;
    }
    fetch('/cart.js')
      .then(function(r) { return r.json(); })
      .then(function(cart) {
        var inCart = 0;
        cart.items.forEach(function(item) {
          if (item.variant_id == variantId) inCart += item.quantity;
        });
        var addBtn = btn || document.getElementById('add-to-cart-btn');
        if (inCart >= inventoryQty) {
          addBtn.disabled = true;
          addBtn.textContent = 'Esgotado';
        } else {
          addBtn.disabled = false;
          addBtn.textContent = 'Adicionar ao Carrinho';
        }
      })
      .catch(function() {
        if (btn) { btn.disabled = false; btn.textContent = 'Adicionar ao Carrinho'; }
      });
  }
</script>


