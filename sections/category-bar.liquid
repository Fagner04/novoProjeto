<div class="category-bar">
  <div class="category-bar-inner">
    <a href="/collections/all" class="category-bar-link {% if request.path == '/collections/all' %}active{% endif %}">
      Todos
    </a>
    {% for block in section.blocks %}
      <a
        href="{{ block.settings.link }}"
        class="category-bar-link {% if request.path == block.settings.link %}active{% endif %}"
      >
        {{ block.settings.label }}
      </a>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Barra de Categorias",
  "blocks": [
    {
      "type": "category",
      "name": "Categoria",
      "settings": [
        { "type": "text", "id": "label", "label": "Nome", "default": "Categoria" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Barra de Categorias",
      "blocks": [
        { "type": "category", "settings": { "label": "Tops", "link": "/collections/tops" } },
        { "type": "category", "settings": { "label": "Leggings", "link": "/collections/leggings" } },
        { "type": "category", "settings": { "label": "Conjuntos", "link": "/collections/conjuntos" } },
        { "type": "category", "settings": { "label": "Shorts", "link": "/collections/shorts" } },
        { "type": "category", "settings": { "label": "Acessórios", "link": "/collections/acessorios" } }
      ]
    }
  ]
}
{% endschema %}
