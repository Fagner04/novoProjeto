<style>
  .footer-payment-icons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }
  .payment-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    background: #f4f4f5;
    border: 1px solid #e4e4e7;
    border-radius: 0.5rem;
    padding: 0.4rem 0.6rem;
    font-size: 0.65rem;
    color: #52525b;
    font-weight: 600;
    min-width: 52px;
  }
  .payment-badge svg { color: #71449b; }
</style>

<footer class="site-footer" id="contact">
  <div class="footer-inner">
    <div class="footer-grid">

      {% for block in section.blocks %}

        {% if block.type == 'brand' %}
        <div class="footer-brand" {{ block.shopify_attributes }}>
          <h3>{{ block.settings.title | default: shop.name }}</h3>
          <p>{{ block.settings.description }}</p>
          {% if block.settings.show_contact %}
            <p style="font-size:0.75rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:0.5rem;">Atendimento ao Cliente</p>
            <div class="footer-contact">
              {% if block.settings.email != blank %}
                <a href="mailto:{{ block.settings.email }}">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                  {{ block.settings.email }}
                </a>
              {% endif %}
              {% if block.settings.whatsapp != blank %}
                <a href="https://wa.me/{{ block.settings.whatsapp }}" target="_blank" rel="noopener">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                  {{ block.settings.whatsapp_label | default: block.settings.whatsapp }}
                </a>
              {% endif %}
            </div>
          {% endif %}
          {% if block.settings.show_social %}
            <div class="footer-social">
              {% if block.settings.social_instagram != blank %}
                <a href="{{ block.settings.social_instagram }}" target="_blank" rel="noopener" aria-label="Instagram">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                </a>
              {% endif %}
              {% if block.settings.social_facebook != blank %}
                <a href="{{ block.settings.social_facebook }}" target="_blank" rel="noopener" aria-label="Facebook">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                </a>
              {% endif %}
              {% if block.settings.social_tiktok != blank %}
                <a href="{{ block.settings.social_tiktok }}" target="_blank" rel="noopener" aria-label="TikTok">
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z"/></svg>
                </a>
              {% endif %}
            </div>
          {% endif %}
        </div>

        {% elsif block.type == 'menu' %}
        <div class="footer-col" {{ block.shopify_attributes }}>
          <h4>{{ block.settings.title }}</h4>
          <ul>
            {% for link in linklists[block.settings.menu].links %}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {% endfor %}
          </ul>
        </div>

        {% elsif block.type == 'newsletter' %}
        <div class="footer-col" {{ block.shopify_attributes }}>
          <h4>{{ block.settings.title | default: 'Newsletter' }}</h4>
          <p style="font-size:0.875rem;color:rgba(24,24,27,0.7);margin-bottom:1rem;">{{ block.settings.description | default: 'Receba novidades e ofertas exclusivas' }}</p>
          <form class="footer-newsletter" action="/contact#newsletter" method="post" accept-charset="UTF-8">
            <input type="hidden" name="form_type" value="customer">
            <input type="hidden" name="utf8" value="✓">
            <input type="hidden" name="contact[tags]" value="newsletter">
            <input type="email" name="contact[email]" placeholder="Seu e-mail" required>
            <button type="submit">{{ block.settings.btn_label | default: 'Inscrever' }}</button>
          </form>
        </div>

        {% elsif block.type == 'payment' %}
        <div class="footer-col" {{ block.shopify_attributes }}>
          <h4>{{ block.settings.title | default: 'Pagamento' }}</h4>
          <div class="footer-payment-icons">
            {% if block.settings.show_pix %}
              <span class="payment-badge" title="Pix">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="28" height="28"><path d="M12 2L7 7H4a1 1 0 0 0-1 1v3l-1 1 1 1v3a1 1 0 0 0 1 1h3l5 5 5-5h3a1 1 0 0 0 1-1v-3l1-1-1-1V8a1 1 0 0 0-1-1h-3L12 2z"/></svg>
                <span>Pix</span>
              </span>
            {% endif %}
            {% if block.settings.show_credit %}
              <span class="payment-badge" title="Cartão de Crédito">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="28" height="28"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
                <span>Crédito</span>
              </span>
            {% endif %}
            {% if block.settings.show_debit %}
              <span class="payment-badge" title="Cartão de Débito">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="28" height="28"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/><line x1="5" y1="15" x2="9" y2="15"/></svg>
                <span>Débito</span>
              </span>
            {% endif %}
            {% if block.settings.show_boleto %}
              <span class="payment-badge" title="Boleto">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="28" height="28"><rect x="2" y="4" width="20" height="16" rx="2"/><line x1="6" y1="8" x2="6" y2="16"/><line x1="10" y1="8" x2="10" y2="16"/><line x1="14" y1="8" x2="14" y2="16"/><line x1="18" y1="8" x2="18" y2="16"/></svg>
                <span>Boleto</span>
              </span>
            {% endif %}
          </div>
          {% if block.settings.installments != blank %}
            <p style="font-size:0.75rem;color:rgba(24,24,27,0.6);margin-top:0.75rem;">{{ block.settings.installments }}</p>
          {% endif %}
        </div>

        {% endif %}
      {% endfor %}

    </div>

    <div class="footer-bottom">
      <p>© {{ 'now' | date: '%Y' }} {{ shop.name }}. Todos os direitos reservados.</p>
      <p>{{ section.settings.cnpj }}</p>
      <p style="font-size:0.7rem;color:rgba(24,24,27,0.45);">Desenvolvido por <a href="https://fagner-dev.vercel.app" target="_blank" rel="noopener" style="color:rgba(24,24,27,0.55);text-decoration:underline;font-weight:600;">Fagner.dev</a></p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Rodapé",
  "settings": [
    { "type": "text", "id": "cnpj", "label": "CNPJ", "default": "CNPJ: 00.000.000/0001-00" }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Marca / Contato",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "title", "label": "Nome da marca", "default": "MUSAS" },
        { "type": "textarea", "id": "description", "label": "Descrição", "default": "Muito além do básico" },
        { "type": "checkbox", "id": "show_contact", "label": "Mostrar contato", "default": true },
        { "type": "text", "id": "email", "label": "E-mail", "default": "musasclubfit@gmail.com" },
        { "type": "text", "id": "whatsapp", "label": "WhatsApp (só números)", "default": "5562994319090" },
        { "type": "text", "id": "whatsapp_label", "label": "Texto do WhatsApp", "default": "+55 62 99431-9090" },
        { "type": "checkbox", "id": "show_social", "label": "Mostrar redes sociais", "default": true },
        { "type": "text", "id": "social_instagram", "label": "Instagram (URL)" },
        { "type": "text", "id": "social_facebook", "label": "Facebook (URL)" },
        { "type": "text", "id": "social_tiktok", "label": "TikTok (URL)" }
      ]
    },
    {
      "type": "menu",
      "name": "Menu de links",
      "settings": [
        { "type": "text", "id": "title", "label": "Título", "default": "Links" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "title", "label": "Título", "default": "Newsletter" },
        { "type": "text", "id": "description", "label": "Descrição", "default": "Receba novidades e ofertas exclusivas" },
        { "type": "text", "id": "btn_label", "label": "Texto do botão", "default": "Inscrever" }
      ]
    },
    {
      "type": "payment",
      "name": "Formas de Pagamento",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "title", "label": "Título", "default": "Pagamento" },
        { "type": "checkbox", "id": "show_pix", "label": "Mostrar Pix", "default": true },
        { "type": "checkbox", "id": "show_credit", "label": "Mostrar Cartão de Crédito", "default": true },
        { "type": "checkbox", "id": "show_debit", "label": "Mostrar Cartão de Débito", "default": true },
        { "type": "checkbox", "id": "show_boleto", "label": "Mostrar Boleto", "default": true },
        { "type": "text", "id": "installments", "label": "Texto de parcelamento", "default": "Em até 6x sem juros no cartão" }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "brand",
        "settings": {
          "title": "MUSAS",
          "description": "Muito além do básico",
          "email": "musasclubfit@gmail.com",
          "whatsapp": "5562994319090",
          "whatsapp_label": "+55 62 99431-9090",
          "show_contact": true,
          "show_social": true,
          "social_instagram": "https://www.instagram.com/musasclubfit",
          "social_facebook": "",
          "social_tiktok": ""
        }
      },
      { "type": "menu", "settings": { "title": "Central de Atendimento" } },
      { "type": "menu", "settings": { "title": "Institucional" } },
      { "type": "newsletter", "settings": {} },
      { "type": "payment", "settings": { "show_pix": true, "show_credit": true, "show_debit": true, "show_boleto": true, "installments": "Em até 6x sem juros no cartão" } }
    ]
  }
}
{% endschema %}
