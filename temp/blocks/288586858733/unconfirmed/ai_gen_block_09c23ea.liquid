{% doc %}
  @prompt
    Um layout editorial no estilo de revista
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-editorial-layout-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-editorial-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .ai-editorial-card-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.card_border_radius }}px;
    background-color: {{ block.settings.card_background }};
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .ai-editorial-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15);
  }

  .ai-editorial-card-{{ ai_gen_id }}--featured {
    grid-column: span 8;
    grid-row: span 2;
  }

  .ai-editorial-card-{{ ai_gen_id }}--medium {
    grid-column: span 4;
  }

  .ai-editorial-card-{{ ai_gen_id }}--small {
    grid-column: span 4;
  }

  .ai-editorial-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .ai-editorial-card-{{ ai_gen_id }}--featured .ai-editorial-image-wrapper-{{ ai_gen_id }} {
    height: 500px;
  }

  .ai-editorial-card-{{ ai_gen_id }}--medium .ai-editorial-image-wrapper-{{ ai_gen_id }} {
    height: 240px;
  }

  .ai-editorial-card-{{ ai_gen_id }}--small .ai-editorial-image-wrapper-{{ ai_gen_id }} {
    height: 200px;
  }

  .ai-editorial-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-editorial-card-{{ ai_gen_id }}:hover .ai-editorial-image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-editorial-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #e0e0e0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-editorial-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-editorial-category-{{ ai_gen_id }} {
    position: absolute;
    top: 16px;
    left: 16px;
    background-color: {{ block.settings.category_bg_color }};
    color: {{ block.settings.category_text_color }};
    padding: 6px 12px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    z-index: 2;
  }

  .ai-editorial-content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .ai-editorial-title-{{ ai_gen_id }} {
    color: {{ block.settings.title_color }};
    margin: 0 0 12px;
    line-height: 1.3;
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
  }

  .ai-editorial-card-{{ ai_gen_id }}--featured .ai-editorial-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.featured_title_size }}px;
  }

  .ai-editorial-card-{{ ai_gen_id }}--medium .ai-editorial-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.medium_title_size }}px;
  }

  .ai-editorial-card-{{ ai_gen_id }}--small .ai-editorial-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.small_title_size }}px;
  }

  .ai-editorial-excerpt-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
    margin: 0 0 16px;
    flex-grow: 1;
  }

  .ai-editorial-card-{{ ai_gen_id }}--small .ai-editorial-excerpt-{{ ai_gen_id }} {
    display: none;
  }

  .ai-editorial-meta-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 13px;
    color: {{ block.settings.meta_color }};
    margin-top: auto;
  }

  .ai-editorial-author-{{ ai_gen_id }} {
    font-weight: 600;
  }

  .ai-editorial-date-{{ ai_gen_id }} {
    opacity: 0.8;
  }

  .ai-editorial-link-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    text-indent: -9999px;
  }

  @media screen and (max-width: 989px) {
    .ai-editorial-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(6, 1fr);
      gap: {{ block.settings.grid_gap | times: 0.75 }}px;
    }

    .ai-editorial-card-{{ ai_gen_id }}--featured {
      grid-column: span 6;
      grid-row: span 1;
    }

    .ai-editorial-card-{{ ai_gen_id }}--medium {
      grid-column: span 6;
    }

    .ai-editorial-card-{{ ai_gen_id }}--small {
      grid-column: span 6;
    }

    .ai-editorial-card-{{ ai_gen_id }}--featured .ai-editorial-image-wrapper-{{ ai_gen_id }} {
      height: 350px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-editorial-layout-{{ ai_gen_id }} {
      width: 100%;
      padding: {{ block.settings.section_padding | times: 0.6 }}px 16px;
    }

    .ai-editorial-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.grid_gap | times: 0.5 }}px;
    }

    .ai-editorial-card-{{ ai_gen_id }}--featured,
    .ai-editorial-card-{{ ai_gen_id }}--medium,
    .ai-editorial-card-{{ ai_gen_id }}--small {
      grid-column: span 1;
    }

    .ai-editorial-card-{{ ai_gen_id }}--featured .ai-editorial-image-wrapper-{{ ai_gen_id }} {
      height: 250px;
    }

    .ai-editorial-card-{{ ai_gen_id }}--medium .ai-editorial-image-wrapper-{{ ai_gen_id }},
    .ai-editorial-card-{{ ai_gen_id }}--small .ai-editorial-image-wrapper-{{ ai_gen_id }} {
      height: 200px;
    }

    .ai-editorial-card-{{ ai_gen_id }}--small .ai-editorial-excerpt-{{ ai_gen_id }} {
      display: block;
    }
  }
{% endstyle %}

<editorial-layout-{{ ai_gen_id }}
  class="ai-editorial-layout-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
