        "info": "Ex: 5562994319090 (sem + ou espaços)"
      },
      {
        "type": "text",
        "id": "wa_agent_name",
        "label": "Nome do atendente",
        "default": "Musas Atendimento"
      },
      {
        "type": "text",
        "id": "wa_status",
        "label": "Status exibido",
        "default": "Offline"
      },
      {
        "type": "header",
        "content": "Mensagens"
      },
      {
        "type": "textarea",
        "id": "wa_welcome",
        "label": "Mensagem de boas-vindas",
        "default": "👋 Olá! Bem-vindo à Musas! Como posso ajudar você hoje?"
      },
      {
        "type": "text",
        "id": "wa_default_msg",
        "label": "Mensagem padrão (campo vazio)",
        "default": "Olá! Vim pelo site e gostaria de mais informações."
      },
      {
        "type": "text",
        "id": "wa_footer",
        "label": "Texto do rodapé",
        "default": "Resposta em até 2 horas durante horário comercial"
      },
      {
        "type": "header",
        "content": "Bolinha de mensagem (ciclo)"
      },
      {
        "type": "textarea",
        "id": "wa_bubble_messages",
        "label": "Mensagens do ciclo (uma por linha)",
        "default": "Precisa rastrear seu pedido? 📦\nFrete grátis acima de R$299! 🚚\nTroca fácil em até 30 dias! 🔄"
      },
      {
        "type": "range",
        "id": "wa_show_delay",
        "label": "Aparecer após (segundos)",
        "min": 1,
        "max": 30,
        "step": 1,
        "default": 3
      },
      {
        "type": "range",
        "id": "wa_hide_after",
        "label": "Sumir após (segundos)",
        "min": 2,
        "max": 20,
        "step": 1,
        "default": 5
      },
      {
        "type": "range",
        "id": "wa_repeat_after",
        "label": "Repetir a cada (segundos)",
        "min": 5,
        "max": 120,
        "step": 5,
        "default": 30
      }
    ]
