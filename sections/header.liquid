<style>
  :root {
    --header-nav-hover-color: {{ section.settings.nav_hover_color | default: '#fe7e41' }};
    --header-nav-active-color: {{ section.settings.nav_active_color | default: '#fe7e41' }};
    --header-nav-active-underline: {{ section.settings.nav_active_underline | default: '#fe7e41' }};
  }
  .header-nav-link:hover,
  .header-nav a:hover { color: var(--header-nav-hover-color) !important; }
  .header-nav-link::after { background: var(--header-nav-active-underline) !important; }
  .header-nav-link.active { color: var(--header-nav-active-color) !important; }
  .header-icon-btn:hover { color: var(--header-nav-hover-color) !important; }
</style>

<header class="site-header" id="site-header">
  <div class="header-inner">

    <!-- Mobile menu toggle -->
    <button class="header-icon-btn" onclick="toggleMobileMenu()" aria-label="Menu" id="menu-btn">      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>

    <!-- Logo -->
    <a href="/" class="header-logo" style="display:flex;align-items:center;">
      {% if section.settings.logo != blank %}
        <img src="{{ section.settings.logo | image_url: width: 160 }}" alt="{{ shop.name }}" height="40">
      {% else %}
        <span>{{ shop.name | upcase }}</span>
      {% endif %}
    </a>

    <!-- Desktop Nav -->
    <nav class="header-nav">
      {% for link in linklists[section.settings.menu].links %}
        <a href="{{ link.url }}" class="header-nav-link">
          <span class="header-nav-icon">
            {% assign t = link.title | downcase %}
            {% if t contains 'catálog' or t contains 'catalog' or t contains 'loja' or t contains 'produto' %}
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            {% elsif t contains 'rastreio' or t contains 'rastrear' or t contains 'pedido' %}
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 3h15v13H1z"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            {% elsif t contains 'coleção' or t contains 'colecao' or t contains 'novidade' or t contains 'nova' %}
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            {% elsif t contains 'frete' or t contains 'entrega' or t contains 'calcular' %}
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
            {% elsif t contains 'sobre' or t contains 'quem' %}
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            {% elsif t contains 'contato' or t contains 'whatsapp' or t contains 'falar' %}
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            {% elsif t contains 'promoção' or t contains 'promocao' or t contains 'oferta' or t contains 'sale' %}
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
            {% else %}
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 8 12 12 14 14"/></svg>
            {% endif %}
          </span>
          {{ link.title }}
        </a>
      {% endfor %}
    </nav>

    <!-- Desktop Search inline -->
    <form action="/search" method="get" class="header-search-form" id="search-form" autocomplete="off">
      <input type="hidden" name="type" value="product">
      <svg class="header-search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input type="search" name="q" id="search-input" placeholder="Pesquisar aqui..." class="header-search-input" aria-label="Pesquisar" aria-autocomplete="list" aria-controls="search-results">
      <button type="button" class="header-mic-btn" aria-label="Pesquisa por voz">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
          <rect x="9" y="2" width="6" height="11" rx="3" fill="#4285F4"/>
          <path d="M5 10a7 7 0 0 0 14 0" stroke="#EA4335" stroke-width="2" fill="none" stroke-linecap="round"/>
          <line x1="12" y1="17" x2="12" y2="21" stroke="#34A853" stroke-width="2" stroke-linecap="round"/>
          <line x1="9" y1="21" x2="15" y2="21" stroke="#FBBC05" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </button>
      <div id="search-results" class="search-autocomplete" role="listbox" style="display:none;"></div>
    </form>

    <style>
      .header-search-form { position: relative; }
      .search-autocomplete {
        position: absolute;
        top: calc(100% + 8px);
        left: 0; right: 0;
        background: #fff;
        border-radius: 1rem;
        box-shadow: 0 8px 32px rgba(0,0,0,0.14);
        overflow: hidden;
        z-index: 9000;
        max-height: 420px;
        overflow-y: auto;
      }
      .search-autocomplete a {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.65rem 1rem;
        text-decoration: none;
        color: #18181b;
        font-size: 0.875rem;
        transition: background 0.15s;
        border-bottom: 1px solid #f4f4f5;
      }
      .search-autocomplete a:last-child { border-bottom: none; }
      .search-autocomplete a:hover { background: #f9f9fb; }
      .search-autocomplete img {
        width: 44px; height: 44px;
        object-fit: cover;
        border-radius: 0.5rem;
        flex-shrink: 0;
        background: #f4f4f5;
      }
      .search-ac-info { display: flex; flex-direction: column; gap: 0.15rem; min-width: 0; }
      .search-ac-title { font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
      .search-ac-price { font-size: 0.8rem; color: #71449b; font-weight: 700; }
      .search-ac-empty { padding: 1rem; text-align: center; color: #71717a; font-size: 0.875rem; }
      .search-ac-loading { padding: 1rem; text-align: center; color: #a1a1aa; font-size: 0.8rem; }
    </style>

    <script>
    (function(){
      function initSearch() {
        var input = document.getElementById('search-input');
        var box   = document.getElementById('search-results');
        if(!input || !box) return;
        var timer;

        function tryFetch() {
          clearTimeout(timer);
          var q = input.value.trim();
          if(q.length < 2){ box.style.display='none'; return; }
          box.innerHTML = '<div class="search-ac-loading">Buscando...</div>';
          box.style.display = 'block';
          timer = setTimeout(function(){ fetchSuggestions(q); }, 280);
        }

        input.addEventListener('input', tryFetch);
        input.addEventListener('keyup', tryFetch);
        input.addEventListener('focus', function(){
          if(input.value.trim().length >= 2) tryFetch();
        });

        input.addEventListener('keydown', function(e){
          if(e.key === 'Escape'){ box.style.display='none'; }
        });

        document.addEventListener('click', function(e){
          if(!e.target.closest('#search-form')){ box.style.display='none'; }
        });

        function fetchSuggestions(q){
          var controller = typeof AbortController !== 'undefined' ? new AbortController() : null;
          var timeoutId = setTimeout(function(){
            if(controller) controller.abort();
            box.innerHTML = '<div class="search-ac-empty">Tempo esgotado. <a href="/search?q=' + encodeURIComponent(q) + '&type=product" style="color:#7c3aed;">Ver todos resultados</a></div>';
            box.style.display = 'block';
          }, 4000);

          fetch('/search/suggest.json?q=' + encodeURIComponent(q) + '&resources[type]=product&resources[limit]=6&resources[options][fields]=title,product_type,variants.title,vendor', controller ? { signal: controller.signal } : {})
            .then(function(r){ return r.json(); })
            .then(function(data){
              clearTimeout(timeoutId);
              var products = (data.resources && data.resources.results && data.resources.results.products) || [];
              if(products.length === 0){
                box.innerHTML = '<div class="search-ac-empty">Nenhum produto encontrado. <a href="/search?q=' + encodeURIComponent(q) + '&type=product" style="color:#7c3aed;">Busca completa</a></div>';
                box.style.display = 'block';
                return;
              }
              box.innerHTML = products.map(function(p){
                var imgSrc = p.featured_image ? (p.featured_image.indexOf('?') > -1 ? p.featured_image + '&width=100' : p.featured_image + '?width=100') : '';
                var img = imgSrc
                  ? '<img src="' + imgSrc + '" alt="' + p.title.replace(/"/g,'&quot;') + '">'
                  : '<div style="width:44px;height:44px;border-radius:8px;background:#f4f4f5;flex-shrink:0;display:flex;align-items:center;justify-content:center;"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg></div>';
                var price = p.price ? '<span class="search-ac-price">R$ ' + (p.price / 100).toFixed(2).replace('.',',') + '</span>' : '';
                return '<a href="' + p.url + '">' + img + '<span class="search-ac-info"><span class="search-ac-title">' + p.title + '</span>' + price + '</span></a>';
              }).join('');
              box.style.display = 'block';
            })
            .catch(function(){
              clearTimeout(timeoutId);
              box.innerHTML = '<div class="search-ac-empty"><a href="/search?q=' + encodeURIComponent(q) + '&type=product" style="color:#7c3aed;font-weight:600;">🔍 Ver resultados para "' + q + '"</a></div>';
              box.style.display = 'block';
            });
        }
      }

      if(document.readyState === 'loading'){
        document.addEventListener('DOMContentLoaded', initSearch);
      } else {
        initSearch();
      }
    })();
    </script>

    <!-- Actions -->
    <div class="header-actions">
      <a href="/pages/favoritos" class="header-icon-btn" aria-label="Favoritos" style="position:relative;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
        </svg>
        <span class="cart-badge" id="fav-count" style="display:none;">0</span>
      </a>
      {% if customer %}
        <a href="/account" class="header-icon-btn" aria-label="Minha conta">
      {% else %}
        <a href="{{ section.settings.account_login_url | default: '/account/login' }}" class="header-icon-btn" aria-label="Minha conta">
      {% endif %}
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
        </svg>
      </a>

      <button class="header-icon-btn" aria-label="Carrinho" id="cart-btn">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        <span class="cart-badge" id="cart-count" style="display:none;">0</span>
      </button>
    </div>

  </div>


</header>

<!-- Mobile Menu -->
<div class="mobile-menu" id="mobile-menu">

  <!-- Header do menu -->
  <div class="mobile-menu-header">
    <a href="/" class="mobile-menu-logo" onclick="toggleMobileMenu()">
      {% if section.settings.logo != blank %}
        <img src="{{ section.settings.logo | image_url: width: 160 }}" alt="{{ shop.name }}" height="36">
      {% else %}
        <span>{{ shop.name | upcase }}</span>
      {% endif %}
    </a>
    <button class="mobile-menu-close" onclick="toggleMobileMenu()" aria-label="Fechar menu">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <!-- Search mobile -->
  <form action="/search" method="get" class="mobile-menu-search">
    <input type="hidden" name="type" value="product">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
    </svg>
    <input type="search" name="q" placeholder="Pesquisar produtos...">
  </form>

  <!-- Nav links do menu Shopify -->
  <nav class="mobile-menu-nav">
    {% for link in linklists[section.settings.menu].links %}
      <a href="{{ link.url }}" onclick="toggleMobileMenu()">
        <span>{{ link.title }}</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
      </a>
    {% endfor %}
  </nav>

  <!-- Divisor -->
  <div class="mobile-menu-divider"></div>

  <!-- Conta e WhatsApp -->
  <div class="mobile-menu-footer-links">
    {% if customer %}
      <a href="/account" onclick="toggleMobileMenu()" class="mobile-menu-account">
    {% else %}
      <a href="{{ section.settings.account_login_url | default: '/account/login' }}" onclick="toggleMobileMenu()" class="mobile-menu-account">
    {% endif %}
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
      </svg>
      Minha Conta
    </a>
    <a href="/pages/favoritos" onclick="toggleMobileMenu()" class="mobile-menu-account">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
      </svg>
      Meus Favoritos
    </a>
    <a href="https://wa.me/5562994319090" target="_blank" rel="noopener" class="mobile-menu-whatsapp">
      <svg width="18" height="18" viewBox="0 0 32 32" fill="none">
        <path d="M16 2C8.268 2 2 8.268 2 16c0 2.478.648 4.805 1.782 6.82L2 30l7.38-1.754A13.94 13.94 0 0 0 16 30c7.732 0 14-6.268 14-14S23.732 2 16 2z" fill="#25D366"/>
        <path d="M23.1 19.6c-.3-.15-1.77-.87-2.04-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.27-.47-2.42-1.49-.9-.8-1.5-1.78-1.68-2.08-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.51-.17-.01-.37-.01-.57-.01-.2 0-.52.07-.8.37-.27.3-1.04 1.02-1.04 2.48 0 1.46 1.07 2.87 1.22 3.07.15.2 2.1 3.2 5.08 4.49.71.31 1.27.49 1.7.63.72.23 1.37.2 1.88.12.57-.09 1.77-.72 2.02-1.42.25-.7.25-1.3.17-1.42-.07-.12-.27-.2-.57-.35z" fill="#fff"/>
      </svg>
      Falar no WhatsApp
    </a>
  </div>

</div>

<script>
(function(){
  document.addEventListener('DOMContentLoaded', function(){
    var btn    = document.getElementById('cart-btn');
    var drawer = document.getElementById('cart-drawer');
    if (!btn || !drawer) return;

    btn.addEventListener('click', function(){
      if (drawer.classList.contains('open')) {
        closeCart();
      } else {
        openCart();
      }
    });

    // Fecha ao clicar fora (bubble, depois do btn click)
    document.addEventListener('click', function(e){
      if (drawer.classList.contains('open') && !drawer.contains(e.target) && !btn.contains(e.target)) {
        closeCart();
      }
    });
  });
})();
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu de navegação",
      "default": "main-menu"
    },
    {
      "type": "header",
      "content": "Cores do menu"
    },
    {
      "type": "color",
      "id": "nav_hover_color",
      "label": "Cor ao passar o mouse (hover)",
      "default": "#fe7e41"
    },
    {
      "type": "color",
      "id": "nav_active_color",
      "label": "Cor do link ativo",
      "default": "#fe7e41"
    },
    {
      "type": "color",
      "id": "nav_active_underline",
      "label": "Cor do sublinhado ao passar o mouse",
      "default": "#fe7e41"
    },
    {
      "type": "header",
      "content": "Conta do usuário"
    },
    {
      "type": "url",
      "id": "account_login_url",
      "label": "Link do ícone de conta (login)",
      "info": "Padrão: /account/login. Pode apontar para uma página personalizada."
    }
  ]
}
{% endschema %}
