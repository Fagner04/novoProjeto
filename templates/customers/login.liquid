<div class="product-page">
  <div class="container-elegant" style="max-width:28rem;">

    <div class="section-header" style="margin-bottom:2rem;">
      <h1 class="heading-section">Entrar</h1>
    </div>

    {% form 'customer_login' %}
      {% if form.errors %}
        <div style="background:#fee2e2;border:1px solid #fca5a5;padding:1rem;border-radius:0.5rem;margin-bottom:1rem;font-size:0.875rem;color:#dc2626;">
          {{ form.errors | default_errors }}
        </div>
      {% endif %}

      <div style="display:flex;flex-direction:column;gap:1rem;margin-bottom:1.5rem;">
        <div>
          <label style="font-size:0.75rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;display:block;margin-bottom:0.5rem;">E-mail</label>
          <input type="email" name="customer[email]" autocomplete="email"
            style="width:100%;padding:0.75rem 1rem;border:1px solid var(--border);border-radius:0.5rem;font-size:1rem;outline:none;"
            required>
        </div>
        <div>
          <label style="font-size:0.75rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;display:block;margin-bottom:0.5rem;">Senha</label>
          <input type="password" name="customer[password]" autocomplete="current-password"
            style="width:100%;padding:0.75rem 1rem;border:1px solid var(--border);border-radius:0.5rem;font-size:1rem;outline:none;"
            required>
        </div>
      </div>

      <button type="submit" class="btn-primary btn-musas" style="width:100%;border-radius:9999px;justify-content:center;">
        Entrar
      </button>

      <div style="display:flex;justify-content:space-between;margin-top:1rem;font-size:0.875rem;">
        <a href="{{ routes.account_recover_url }}" style="color:var(--muted-foreground);">Esqueci minha senha</a>
        <a href="{{ routes.account_register_url }}" style="color:var(--brand-orange);">Criar conta</a>
      </div>
    {% endform %}

  </div>
</div>
