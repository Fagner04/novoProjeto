    }

    customElements.define('editorial-layout-{{ ai_gen_id }}', EditorialLayout{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Layout editorial",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Artigos"
    },
    {
      "type": "article",
      "id": "featured_article",
      "label": "Artigo em destaque"
    },
    {
      "type": "article",
      "id": "article_2",
      "label": "Artigo 2"
    },
    {
      "type": "article",
      "id": "article_3",
      "label": "Artigo 3"
    },
    {
      "type": "article",
      "id": "article_4",
      "label": "Artigo 4"
    },
    {
      "type": "article",
      "id": "article_5",
      "label": "Artigo 5"
    },
    {
      "type": "article",
      "id": "article_6",
      "label": "Artigo 6"
    },
    {
      "type": "header",
      "content": "Exibição"
    },
    {
      "type": "checkbox",
      "id": "show_category",
      "label": "Mostrar categoria",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "label": "Mostrar autor",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "Mostrar data",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Largura no desktop",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Espaçamento da seção",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Espaço entre cards",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "card_padding",
      "label": "Espaçamento interno do card",
      "min": 10,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Arredondamento do card",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Tipografia"
    },
    {
      "type": "font_picker",
      "id": "title_font",
      "label": "Fonte dos títulos",
      "default": "merriweather_n4"
    },
    {
      "type": "range",
      "id": "featured_title_size",
      "label": "Tamanho do título em destaque",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "medium_title_size",
      "label": "Tamanho do título médio",
      "min": 16,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "small_title_size",
      "label": "Tamanho do título pequeno",
      "min": 14,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Tamanho do texto",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "header",
      "content": "Cores"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Fundo da seção",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Fundo do card",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Cor do título",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Cor do texto",
      "default": "#666666"
    },
    {
