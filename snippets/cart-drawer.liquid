<div class="cart-overlay" id="cart-overlay" onclick="closeCart()"></div>

<div class="cart-drawer" id="cart-drawer" aria-label="Carrinho">
  <div class="cart-drawer-header">
    <h2>Carrinho</h2>
    <button class="cart-close" onclick="closeCart()" aria-label="Fechar carrinho">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <div class="cart-items" id="cart-items-list">
    <!-- Populated by JS -->
    <div class="cart-empty" id="cart-empty">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color:var(--muted-foreground)">
        <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/>
        <path d="M16 10a4 4 0 0 1-8 0"/>
      </svg>
      <p>Seu carrinho está vazio</p>
      <a href="/collections/all" onclick="closeCart()" class="btn-primary btn-musas" style="border-radius:9999px;font-size:0.75rem;padding:0.75rem 1.5rem;">Ver Produtos</a>
    </div>
  </div>

  <div class="cart-footer" id="cart-footer" style="display:none;">
    <div id="cw-wholesale-progress-container"></div>

    <!-- Aviso de mínimo de acessórios para atacado -->
    {% if settings.atacado_acessorio_enabled %}
    <div id="cart-acessorio-warning" style="display:none;margin-bottom:0.75rem;">
      <div id="cart-acessorio-items"></div>
    </div>
    {% endif %}

    <div class="cart-total">
      <span>Total</span>
      <span id="cart-total-price">R$ 0,00</span>
    </div>
    <a href="/checkout" class="cart-checkout-btn" id="cart-checkout-btn">
      Finalizar Compra
    </a>
    <p style="font-size:0.75rem;color:var(--muted-foreground);text-align:center;margin-top:0.75rem;">
      🔒 Pagamento 100% seguro
    </p>
  </div>
</div>

{% if settings.atacado_acessorio_enabled %}
<script>
(function(){
  var ACESSORIO_TAG = {{ settings.atacado_acessorio_tag | json }};
  var ACESSORIO_MIN_VALUE = parseFloat({{ settings.atacado_acessorio_min_value | default: '100.00' | json }}) * 100;
  var ACESSORIO_MSG = {{ settings.atacado_acessorio_msg | default: 'Valor mínimo deste produto' | json }};

  // Cache de tags por handle buscadas via API
  var _tagsCache = {};

  function getProductTags(handle) {
    if (_tagsCache[handle] !== undefined) return Promise.resolve(_tagsCache[handle]);
    return fetch('/products/' + handle + '.js')
      .then(function(r){ return r.json(); })
      .then(function(p){
        _tagsCache[handle] = (p.tags || []).map(function(t){ return t.toLowerCase().trim(); });
        return _tagsCache[handle];
      })
      .catch(function(){ _tagsCache[handle] = []; return []; });
  }

  function checkAcessorioRule(cartItems) {
    console.log('[ACESSORIO] TAG buscada:', ACESSORIO_TAG);
    console.log('[ACESSORIO] MIN_VALUE (centavos):', ACESSORIO_MIN_VALUE);
    console.log('[ACESSORIO] cartItems:', cartItems.map(function(i){ return {handle: i.handle, title: i.product_title}; }));

    var warning = document.getElementById('cart-acessorio-warning');
    var container = document.getElementById('cart-acessorio-items');
    if (!warning || !container) return;

    // Busca tags de todos os produtos únicos
    var handles = [...new Set(cartItems.map(function(i){ return i.handle; }))];
    Promise.all(handles.map(getProductTags)).then(function() {
      console.log('[ACESSORIO] Tags cache:', JSON.stringify(_tagsCache));
      var acessoriosByProduct = {};
      cartItems.forEach(function(item) {
        var tags = _tagsCache[item.handle] || [];
        if (tags.indexOf(ACESSORIO_TAG.toLowerCase()) > -1) {
          if (!acessoriosByProduct[item.handle]) {
            acessoriosByProduct[item.handle] = { title: item.product_title, qty: 0, total: 0 };
          }
          acessoriosByProduct[item.handle].qty += item.quantity;
          acessoriosByProduct[item.handle].total += item.final_price * item.quantity;
        }
      });

      var productHandles = Object.keys(acessoriosByProduct);
      if (productHandles.length === 0) {
        warning.style.display = 'none';
        return;
      }

      warning.style.display = 'block';
      container.innerHTML = '';

      productHandles.forEach(function(handle) {
        var prod = acessoriosByProduct[handle];
        var pct = Math.min(100, Math.round((prod.total / ACESSORIO_MIN_VALUE) * 100));
        var faltam = Math.max(0, ACESSORIO_MIN_VALUE - prod.total);
        var atingiu = faltam === 0;

        var div = document.createElement('div');
        div.style.cssText = 'margin-bottom:0.625rem;padding:0.75rem 0.875rem;background:#FFF7ED;border-radius:0.75rem;border-left:3px solid ' + (atingiu ? '#16a34a' : '#F97316') + ';';
        div.innerHTML = '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.35rem;">'
          + '<span style="font-size:0.78rem;font-weight:600;color:#9A3412;">🏷️ ' + ACESSORIO_MSG + '</span>'
          + '<span style="font-size:0.78rem;font-weight:700;color:' + (atingiu ? '#16a34a' : '#F97316') + ';">'
          + (atingiu ? '✅ Atacado ativo' : 'Faltam R$ ' + (faltam/100).toFixed(2).replace('.',','))
          + '</span></div>'
          + '<div style="background:#fed7aa;border-radius:9999px;height:5px;overflow:hidden;">'
          + '<div style="height:100%;background:' + (atingiu ? '#16a34a' : '#F97316') + ';border-radius:9999px;width:' + pct + '%;transition:width 0.4s;"></div>'
          + '</div>'
          + (!atingiu ? '<p style="font-size:0.7rem;color:#C2410C;margin:0.25rem 0 0;">Abaixo do mínimo: preço de varejo aplicado</p>' : '');
        container.appendChild(div);
      });
    });
  }

  window.checkAcessorioRule = checkAcessorioRule;
})();
</script>
{% endif %}
