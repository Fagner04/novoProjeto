<section class="hero-section">
  <div class="container-elegant" style="width:100%;position:relative;">
    <div class="hero-bg">
      {% if section.settings.image != blank %}
        <img
          src="{{ section.settings.image | image_url: width: 1920 }}"
          alt="{{ section.settings.title | escape }}"
          loading="eager"
          fetchpriority="high"
          width="1920" height="1080">
      {% else %}
        <div style="width:100%;height:100%;background:linear-gradient(135deg,#2d1f38,#4a3659);"></div>
      {% endif %}
      <div class="hero-overlay"></div>
    </div>

    <div class="hero-content">
      {% if section.settings.tagline != blank %}
        <p class="hero-tagline opacity-0 animate-fade-in-up">{{ section.settings.tagline }}</p>
      {% endif %}
      {% if section.settings.title != blank %}
        <h1 class="hero-title opacity-0 animate-fade-in-up animate-delay-100">{{ section.settings.title }}</h1>
      {% endif %}
      {% if section.settings.subtitle != blank %}
        <p class="hero-subtitle opacity-0 animate-fade-in-up animate-delay-200">{{ section.settings.subtitle }}</p>
      {% endif %}
      <div class="hero-ctas opacity-0 animate-fade-in-up animate-delay-300">
        <a href="{{ section.settings.cta_link | default: '/collections/all' }}" class="hero-cta-primary">
          {{ section.settings.cta_text | default: 'Ver Coleção' }}
        </a>
        <a href="{{ section.settings.cta2_link | default: '/collections/all' }}" class="hero-cta-secondary">
          {{ section.settings.cta2_text | default: 'Comprar Agora' }}
        </a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Imagem de fundo" },
    { "type": "text", "id": "tagline", "label": "Tagline (acima do título)", "default": "Nova Coleção" },
    { "type": "text", "id": "title", "label": "Título principal", "default": "Muito Além do Básico" },
    { "type": "textarea", "id": "subtitle", "label": "Subtítulo", "default": "Peças exclusivas para mulheres que não passam despercebidas" },
    { "type": "text", "id": "cta_text", "label": "Texto do botão 1", "default": "Ver Coleção" },
    { "type": "url", "id": "cta_link", "label": "Link do botão 1" },
    { "type": "text", "id": "cta2_text", "label": "Texto do botão 2", "default": "Comprar Agora" },
    { "type": "url", "id": "cta2_link", "label": "Link do botão 2" }
  ],
  "presets": [{ "name": "Hero Banner" }]
}
{% endschema %}
