<div class="product-page">
  <div class="container-elegant">

    <a href="{{ collection.url | default: '/collections/all' }}" style="display:inline-flex;align-items:center;gap:0.5rem;color:var(--muted-foreground);margin-bottom:2rem;font-size:0.875rem;">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      Voltar
    </a>

    <div class="product-layout">

      <!-- Gallery -->
      <div>
        <div class="product-gallery-main" id="main-image-wrap">
          <img id="main-product-image"
            src="{{ product.featured_image | image_url: width: 800 }}"
            alt="{{ product.featured_image.alt | escape }}"
            width="800" height="1067">
        </div>
        {% if product.images.size > 1 %}
          <div class="product-gallery-thumbs">
            {% for image in product.images %}
              <img
                src="{{ image | image_url: width: 200 }}"
                alt="{{ image.alt | escape }}"
                class="{% if forloop.first %}active{% endif %}"
                onclick="setMainImage('{{ image | image_url: width: 800 }}', this)"
                width="200" height="200">
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <!-- Info -->
      <div class="product-info">
        {% if product.vendor != blank %}
          <p class="label-caps" style="margin-bottom:0.5rem;">{{ product.vendor }}</p>
        {% endif %}

        <h1>{{ product.title }}</h1>

        <div id="product-price-wrap">
          <p class="product-price">
            <span id="selected-price">{{ product.selected_or_first_available_variant.price | money }}</span>
          </p>
          <p class="product-price-pix">
            💚 {{ product.selected_or_first_available_variant.price | times: 0.95 | money }} no PIX (5% off)
          </p>
          <p style="font-size:0.8125rem;color:var(--muted-foreground);margin-bottom:1.5rem;">
            ou 6x de {{ product.selected_or_first_available_variant.price | divided_by: 6 | money }} sem juros
          </p>
        </div>

        <form action="/cart/add" method="post" id="product-form">
          <input type="hidden" name="id" id="variant-id" value="{{ product.selected_or_first_available_variant.id }}">

          {% for option in product.options_with_values %}
            <div class="product-options">
              <label>{{ option.name }}: <strong id="selected-{{ option.name | handleize }}">{{ option.selected_value }}</strong></label>
              <div class="option-buttons">
                {% for value in option.values %}
                  <button type="button"
                    class="option-btn {% if option.selected_value == value %}active{% endif %}"
                    data-option-index="{{ forloop.parentloop.index0 }}"
                    data-option-value="{{ value }}"
                    onclick="selectOption(this, '{{ option.name | handleize }}')">
                    {{ value }}
                  </button>
                {% endfor %}
              </div>
            </div>
          {% endfor %}

          <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1rem;">
            <div class="cart-qty" style="border:1px solid var(--border);border-radius:0.5rem;padding:0.25rem;">
              <button type="button" onclick="changeQty(-1)">−</button>
              <span id="qty-display">1</span>
              <button type="button" onclick="changeQty(1)">+</button>
            </div>
            <input type="hidden" name="quantity" id="qty-input" value="1">
          </div>

          <button type="submit" class="add-to-cart-btn" id="add-to-cart-btn">
            {% if product.selected_or_first_available_variant.available %}
              Adicionar ao Carrinho
            {% else %}
              Indisponível
            {% endif %}
          </button>
        </form>

        <!-- Trust mini badges -->
        <div style="display:flex;gap:1rem;flex-wrap:wrap;margin-top:1rem;padding-top:1rem;border-top:1px solid var(--border);">
          <span style="font-size:0.75rem;color:var(--muted-foreground);display:flex;align-items:center;gap:0.25rem;">
            🔒 Compra segura
          </span>
          <span style="font-size:0.75rem;color:var(--muted-foreground);display:flex;align-items:center;gap:0.25rem;">
            🚚 Frete calculado no checkout
          </span>
          <span style="font-size:0.75rem;color:var(--muted-foreground);display:flex;align-items:center;gap:0.25rem;">
            🔄 Troca fácil
          </span>
        </div>

        {% if product.description != blank %}
          <div class="product-description">
            {{ product.description }}
          </div>
        {% endif %}
      </div>

    </div>

    <!-- Related Products -->
    {% if recommendations.products_count > 0 %}
      <div style="margin-top:4rem;">
        <div class="section-header">
          <p class="label-caps" style="margin-bottom:0.75rem;">Você também pode gostar</p>
          <h2 class="heading-section">Produtos Relacionados</h2>
        </div>
        <div class="products-grid" style="margin-top:2rem;">
          {% for rec in recommendations.products limit: 4 %}
            {% render 'product-card', product: rec %}
          {% endfor %}
        </div>
      </div>
    {% endif %}

  </div>
</div>

<script>
  // Variant selection
  const productVariants = {{ product.variants | json }};
  let selectedOptions = [
    {% for option in product.options_with_values %}"{{ option.selected_value }}"{% unless forloop.last %},{% endunless %}{% endfor %}
  ];

  function selectOption(btn, optionName) {
    const index = parseInt(btn.dataset.optionIndex);
    selectedOptions[index] = btn.dataset.optionValue;

    // Update active state for this option group
    btn.closest('.option-buttons').querySelectorAll('.option-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');

    // Update label
    document.getElementById('selected-' + optionName).textContent = btn.dataset.optionValue;

    // Find matching variant
    const variant = productVariants.find(v =>
      v.options.every((opt, i) => opt === selectedOptions[i])
    );

    if (variant) {
      document.getElementById('variant-id').value = variant.id;
      document.getElementById('selected-price').textContent = formatMoney(variant.price);
      const addBtn = document.getElementById('add-to-cart-btn');
      addBtn.disabled = !variant.available;
      addBtn.textContent = variant.available ? 'Adicionar ao Carrinho' : 'Indisponível';
    }
  }

  function formatMoney(cents) {
    return 'R$ ' + (cents / 100).toFixed(2).replace('.', ',');
  }

  // Quantity
  let qty = 1;
  function changeQty(delta) {
    qty = Math.max(1, qty + delta);
    document.getElementById('qty-display').textContent = qty;
    document.getElementById('qty-input').value = qty;
  }

  // Gallery
  function setMainImage(url, thumb) {
    document.getElementById('main-product-image').src = url;
    document.querySelectorAll('.product-gallery-thumbs img').forEach(i => i.classList.remove('active'));
    thumb.classList.add('active');
  }
</script>
