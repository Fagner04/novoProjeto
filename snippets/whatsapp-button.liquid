{%- assign wa_number = settings.wa_number | default: '5562994319090' -%}
{%- assign wa_agent = settings.wa_agent_name | default: 'Musas Atendimento' -%}
{%- assign wa_status = settings.wa_status | default: 'Offline' -%}
{%- assign wa_status_online = settings.wa_status_online | default: 'Online agora' -%}
{%- assign wa_welcome = settings.wa_welcome | default: '👋 Olá! Bem-vindo à Musas! Como posso ajudar você hoje?' -%}
{%- assign wa_default_msg = settings.wa_default_msg | default: 'Olá! Vim pelo site e gostaria de mais informações.' -%}
{%- assign wa_footer = settings.wa_footer | default: 'Resposta em até 2 horas durante horário comercial' -%}
{%- assign wa_show_delay = settings.wa_show_delay | default: 3 -%}
{%- assign wa_hide_after = settings.wa_hide_after | default: 6 -%}
{%- assign wa_repeat_after = settings.wa_repeat_after | default: 30 -%}
{%- assign wa_schedule_enabled = settings.wa_schedule_enabled | default: true -%}
{%- assign wa_tz_offset = settings.wa_tz_offset | default: '-3' -%}
{%- assign wa_hours_weekday = settings.wa_hours_weekday | default: '09:00-18:00' -%}
{%- assign wa_hours_saturday = settings.wa_hours_saturday | default: '10:00-14:00' -%}
{%- assign wa_hours_sunday = settings.wa_hours_sunday | default: '' -%}
{% if settings.wa_enabled != false %}
<style>
.wac*{box-sizing:border-box;margin:0;padding:0;font-family:'Inter',system-ui,sans-serif;}

/* Root container — row layout: bubble à esquerda, FAB à direita */
.wac-root{
  position:fixed;bottom:1.75rem;right:1.75rem;z-index:9999;
  display:flex;flex-direction:row;align-items:center;gap:.75rem;
}

/* Bubble wrapper — à esquerda do FAB, mesma linha */
.wac-bubble-wrap{
  display:flex;align-items:center;
  visibility:hidden;
  opacity:0;
  transform:translateX(16px);
  transition:visibility 0s .4s, opacity .35s ease, transform .35s cubic-bezier(.34,1.4,.64,1);
  pointer-events:none;
  flex-shrink:1;
}
.wac-bubble-wrap.show{
  visibility:visible;opacity:1;transform:translateX(0);
  transition-delay:0s;pointer-events:auto;
}
/* Bolha estilo WhatsApp — bico apontando para a direita */
.wac-bubble-text{
  background:#fff;color:#111;font-size:.875rem;font-weight:500;
  padding:.6rem 1rem;
  border-radius:1.25rem 1.25rem 1.25rem 1.25rem;
  box-shadow:0 4px 20px rgba(0,0,0,.13);
  max-width:220px;line-height:1.45;
  position:relative;white-space:nowrap;
}
/* Bico da bolha apontando para o FAB (direita) */
.wac-bubble-text::after{
  content:'';position:absolute;right:-8px;top:50%;transform:translateY(-50%);
  border:8px solid transparent;border-left:8px solid #fff;border-right:0;
  filter:drop-shadow(2px 0 2px rgba(0,0,0,.06));
}
.wac-bubble-dots{
  display:flex;align-items:center;gap:4px;padding:.55rem .85rem;
  background:#fff;border-radius:9999px;
  box-shadow:0 4px 20px rgba(0,0,0,.1);
}
.wac-bubble-dots span{width:7px;height:7px;border-radius:9999px;background:#aaa;animation:wacDot 1.3s infinite;}
.wac-bubble-dots span:nth-child(2){animation-delay:.18s;}
.wac-bubble-dots span:nth-child(3){animation-delay:.36s;}
@keyframes wacDot{0%,60%,100%{transform:translateY(0);opacity:.5;}30%{transform:translateY(-5px);opacity:1;}}

/* FAB — standalone, always visible, never affected by bubble visibility */
.wac-fab{
  width:62px;height:62px;border-radius:9999px;
  background:transparent;border:none;cursor:pointer;
  display:flex;align-items:center;justify-content:center;
  box-shadow:none;
  transition:transform .2s;
  flex-shrink:0;
  opacity:1 !important;
  visibility:visible !important;
  pointer-events:auto !important;
}
.wac-fab:hover{transform:scale(1.08);}
.wac-fab.is-open{background:transparent;}
.wac-fab svg{position:relative;z-index:1;}

/* Panel */
.wac-panel{position:fixed;bottom:5.75rem;right:1.75rem;z-index:9998;width:345px;border-radius:1.25rem;overflow:hidden;box-shadow:0 24px 64px rgba(0,0,0,.18),0 4px 16px rgba(0,0,0,.08);background:#f0f2f5;opacity:0;transform:translateY(16px) scale(.96);pointer-events:none;transition:opacity .3s ease,transform .3s cubic-bezier(.34,1.2,.64,1);}
.wac-panel.open{opacity:1;transform:translateY(0) scale(1);pointer-events:all;}

/* Header */
.wac-hdr{background:linear-gradient(135deg,#5b21b6 0%,#7c3aed 100%);padding:1rem 1.1rem;display:flex;align-items:center;gap:.75rem;}
.wac-hdr-av{width:46px;height:46px;border-radius:9999px;background:rgba(255,255,255,.18);display:flex;align-items:center;justify-content:center;flex-shrink:0;position:relative;}
.wac-hdr-dot{position:absolute;bottom:1px;right:1px;width:12px;height:12px;border-radius:9999px;background:#4ade80;border:2.5px solid #7c3aed;}
.wac-hdr-info{flex:1;}
.wac-hdr-name{color:#fff;font-size:.9375rem;font-weight:700;}
.wac-hdr-status{color:rgba(255,255,255,.8);font-size:.75rem;margin-top:.1rem;display:flex;align-items:center;gap:.35rem;}
.wac-hdr-status::before{content:'';width:7px;height:7px;border-radius:9999px;background:#4ade80;flex-shrink:0;}
.wac-hdr-close{background:rgba(255,255,255,.15);border:none;color:#fff;width:32px;height:32px;border-radius:9999px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background .2s;flex-shrink:0;}
.wac-hdr-close:hover{background:rgba(255,255,255,.3);}

/* Messages */
.wac-msgs{padding:1rem;display:flex;flex-direction:column;gap:.6rem;min-height:80px;max-height:200px;overflow-y:auto;background:#f0f2f5;}
.wac-msgs::-webkit-scrollbar{width:3px;}
.wac-msgs::-webkit-scrollbar-thumb{background:rgba(0,0,0,.12);border-radius:9999px;}
.wac-msg{background:#fff;border-radius:0 1rem 1rem 1rem;padding:.7rem .9rem;font-size:.875rem;line-height:1.5;color:#111;box-shadow:0 1px 3px rgba(0,0,0,.07);max-width:88%;opacity:0;transform:translateY(6px);animation:wacMsgIn .35s ease forwards;}
@keyframes wacMsgIn{to{opacity:1;transform:translateY(0);}}
.wac-msg-time{font-size:.68rem;color:#9ca3af;text-align:right;margin-top:.3rem;}
.wac-typing-bubble{background:#fff;border-radius:0 1rem 1rem 1rem;padding:.6rem .8rem;width:fit-content;box-shadow:0 1px 3px rgba(0,0,0,.07);display:flex;gap:4px;align-items:center;}
.wac-typing-bubble span{width:7px;height:7px;border-radius:9999px;background:#bbb;animation:wacDot 1.3s infinite;}
.wac-typing-bubble span:nth-child(2){animation-delay:.18s;}
.wac-typing-bubble span:nth-child(3){animation-delay:.36s;}

/* Quick */
.wac-quick{padding:.5rem 1rem .75rem;display:grid;grid-template-columns:1fr 1fr;gap:.5rem;background:#f0f2f5;}
.wac-qbtn{background:#fff;border:1.5px solid #e5e7eb;border-radius:.875rem;padding:.65rem .7rem;cursor:pointer;display:flex;flex-direction:column;align-items:flex-start;gap:.1rem;transition:all .2s;text-align:left;}
.wac-qbtn:hover{border-color:#7c3aed;background:#faf5ff;transform:translateY(-2px);box-shadow:0 4px 14px rgba(124,58,237,.13);}
.wac-qbtn:active{transform:translateY(0);}
.wac-qi{display:flex;align-items:center;justify-content:center;margin-bottom:.15rem;}
.wac-ql{font-size:.8rem;font-weight:700;color:#7c3aed;}
.wac-qs{font-size:.7rem;color:#6b7280;}

/* Input */
.wac-inp{background:#fff;padding:.75rem 1rem;border-top:1px solid #e9ebee;display:flex;flex-direction:column;gap:.55rem;}
.wac-ta{width:100%;border:1.5px solid #e5e7eb;border-radius:.75rem;padding:.6rem .875rem;font-size:.875rem;color:#111;resize:none;outline:none;transition:border-color .2s;line-height:1.5;background:#fafafa;font-family:inherit;}
.wac-ta:focus{border-color:#7c3aed;background:#fff;}
.wac-ta::placeholder{color:#9ca3af;}
.wac-sbtn{width:100%;padding:.75rem;background:linear-gradient(135deg,#5b21b6,#7c3aed);color:#fff;border:none;border-radius:.875rem;font-size:.875rem;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:.5rem;transition:filter .2s,transform .15s;font-family:inherit;}
.wac-sbtn:hover{filter:brightness(1.1);transform:translateY(-1px);}
.wac-sbtn:active{transform:translateY(0);}
.wac-ft{background:#fff;text-align:center;padding:.55rem 1rem;font-size:.7rem;color:#9ca3af;border-top:1px solid #f3f4f6;}
</style>

<div class="wac-root">
  <!-- Bubble only (no FAB inside) -->
  <div class="wac-bubble-wrap" id="wac-bwrap">
    <div id="wac-bdots" class="wac-bubble-dots" style="display:none;">
      <span></span><span></span><span></span>
    </div>
    <div id="wac-btext" class="wac-bubble-text" style="display:none;"></div>
  </div>

  <!-- FAB — standalone, always visible -->
  <button class="wac-fab" id="wac-fab" onclick="wacToggle()" aria-label="Abrir chat WhatsApp">
    <span id="wac-icon-wa">
      <svg width="52" height="52" viewBox="0 0 52 52" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M26 2C12.745 2 2 12.745 2 26c0 4.243 1.107 8.22 3.048 11.663L2 50l12.69-3.327A23.93 23.93 0 0 0 26 50c13.255 0 24-10.745 24-24S39.255 2 26 2z" fill="#25D366"/>
        <path d="M19.11 14.5c-.457-1.028-.933-1.048-1.368-1.067-.354-.015-.76-.014-1.167-.014-.406 0-1.066.152-1.624.762-.558.61-2.132 2.083-2.132 5.08 0 2.996 2.183 5.893 2.488 6.299.305.406 4.213 6.73 10.413 9.165 5.15 2.031 6.2 1.627 7.315 1.524 1.116-.102 3.604-1.473 4.114-2.895.51-1.422.51-2.641.356-2.895-.152-.254-.558-.406-1.167-.71-.61-.305-3.604-1.778-4.163-1.98-.558-.203-.965-.305-1.37.305-.407.61-1.574 1.98-1.93 2.387-.355.406-.71.457-1.319.152-.61-.305-2.572-.948-4.9-3.022-1.812-1.614-3.034-3.607-3.39-4.217-.355-.61-.038-.94.267-1.244.274-.273.61-.711.914-1.066.305-.356.406-.61.61-1.015.203-.406.101-.762-.051-1.066-.152-.305-1.345-3.314-1.886-4.51z" fill="#fff"/>
      </svg>
    </span>
    <span id="wac-icon-close" style="display:none;">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#25D366" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </span>
  </button>
</div>

<!-- Panel (outside wac-root to avoid stacking issues) -->
<div class="wac-panel" id="wac-panel">
  <div class="wac-hdr">
    <div class="wac-hdr-av">
      <svg width="26" height="26" viewBox="0 0 48 48" fill="none">
        <path d="M24 4C12.954 4 4 12.954 4 24c0 3.59.94 6.96 2.584 9.876L4 44l10.376-2.72A19.88 19.88 0 0 0 24 44c11.046 0 20-8.954 20-20S35.046 4 24 4z" fill="#fff" fill-opacity=".25"/>
        <path d="M34.507 29.13c-.448-.224-2.652-1.308-3.063-1.457-.41-.149-.708-.224-1.007.224-.298.448-1.156 1.457-1.417 1.755-.261.298-.522.336-.97.112-2.67-1.335-4.424-2.382-6.186-5.4-.467-.803.467-.746 1.335-2.484.149-.298.075-.559-.037-.783-.112-.224-1.007-2.428-1.38-3.323-.364-.87-.733-.75-1.007-.764-.261-.013-.559-.016-.857-.016-.298 0-.783.112-1.193.559-.41.448-1.566 1.53-1.566 3.73 0 2.2 1.604 4.327 1.828 4.625.224.298 3.157 4.82 7.65 6.762 2.843 1.228 3.957.944 4.671.783.97-.224 2.652-1.084 3.025-2.132.373-1.048.373-1.946.261-2.132-.112-.186-.41-.298-.857-.522z" fill="#fff"/>
      </svg>
      <div class="wac-hdr-dot"></div>
    </div>
    <div class="wac-hdr-info">
      <div class="wac-hdr-name">{{ wa_agent }}</div>
      <div class="wac-hdr-status" id="wac-status-text">{{ wa_status }}</div>
    </div>
    <button class="wac-hdr-close" onclick="wacToggle()" aria-label="Fechar">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>

  <div class="wac-msgs" id="wac-msgs"></div>

  <div class="wac-quick" id="wac-quick-grid">
    <button class="wac-qbtn" onclick="wacOpenRastreio()">
      <span class="wac-qi"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="1.8"><path d="M1 3h15v13H1z"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg></span>
      <span class="wac-ql">Rastrear</span><span class="wac-qs">Meu pedido</span>
    </button>
    <button class="wac-qbtn" onclick="wacOpenFrete()">
      <span class="wac-qi"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="1.8"><path d="M3 9h18M3 15h18M12 3v18"/><rect x="3" y="3" width="18" height="18" rx="2"/></svg></span>
      <span class="wac-ql">Calcular</span><span class="wac-qs">Frete</span>
    </button>
    <button class="wac-qbtn" onclick="wacSend('Quero informações sobre trocas e devoluções')">
      <span class="wac-qi"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="1.8"><polyline points="1 4 1 10 7 10"/><polyline points="23 20 23 14 17 14"/><path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10M23 14l-4.64 4.36A9 9 0 0 1 3.51 15"/></svg></span>
      <span class="wac-ql">Trocas</span><span class="wac-qs">e devoluções</span>
    </button>
    <button class="wac-qbtn" onclick="wacSend('Quero ver os produtos disponíveis')">
      <span class="wac-qi"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="1.8"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></span>
      <span class="wac-ql">Produtos</span><span class="wac-qs">Ver catálogo</span>
    </button>
  </div>

  <!-- Mini-form: Rastreio -->
  <div id="wac-form-rastreio" style="display:none;padding:.75rem 1rem;background:#f0f2f5;border-top:1px solid #e9ebee;">
    <div style="display:flex;align-items:center;gap:.5rem;margin-bottom:.6rem;">
      <button onclick="wacCloseForm()" style="background:none;border:none;cursor:pointer;color:#7c3aed;font-size:1.1rem;padding:0;" aria-label="Voltar">←</button>
      <span style="font-size:.85rem;font-weight:700;color:#111;">Rastrear meu pedido</span>
    </div>
    <input id="wac-rastreio-input" type="text" placeholder="Digite o código de rastreio (ex: BR123456789BR)"
      style="width:100%;border:1.5px solid #e5e7eb;border-radius:.75rem;padding:.6rem .875rem;font-size:.85rem;outline:none;font-family:inherit;box-sizing:border-box;"
      onkeydown="if(event.key==='Enter')wacDoRastreio()">
    <div style="display:flex;gap:.5rem;margin-top:.5rem;">
      <button onclick="wacDoRastreio()" style="flex:1;padding:.65rem;background:linear-gradient(135deg,#5b21b6,#7c3aed);color:#fff;border:none;border-radius:.75rem;font-size:.82rem;font-weight:700;cursor:pointer;font-family:inherit;">
        🔍 Rastrear nos Correios
      </button>
      <button onclick="wacSend('Quero rastrear meu pedido: '+document.getElementById('wac-rastreio-input').value)" title="Perguntar pelo WhatsApp"
        style="padding:.65rem .85rem;background:#25D366;color:#fff;border:none;border-radius:.75rem;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <svg width="20" height="20" viewBox="0 0 32 32" fill="none"><path d="M16 2C8.268 2 2 8.268 2 16c0 2.478.648 4.805 1.782 6.82L2 30l7.38-1.754A13.94 13.94 0 0 0 16 30c7.732 0 14-6.268 14-14S23.732 2 16 2z" fill="#fff" fill-opacity=".25"/><path d="M23.1 19.6c-.3-.15-1.77-.87-2.04-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.27-.47-2.42-1.49-.9-.8-1.5-1.78-1.68-2.08-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.51-.17-.01-.37-.01-.57-.01-.2 0-.52.07-.8.37-.27.3-1.04 1.02-1.04 2.48 0 1.46 1.07 2.87 1.22 3.07.15.2 2.1 3.2 5.08 4.49.71.31 1.27.49 1.7.63.72.23 1.37.2 1.88.12.57-.09 1.77-.72 2.02-1.42.25-.7.25-1.3.17-1.42-.07-.12-.27-.2-.57-.35z" fill="#fff"/></svg>
      </button>
    </div>
  </div>

  <!-- Mini-form: Calcular Frete -->
  <div id="wac-form-frete" style="display:none;padding:.75rem 1rem;background:#f0f2f5;border-top:1px solid #e9ebee;">
    <div style="display:flex;align-items:center;gap:.5rem;margin-bottom:.6rem;">
      <button onclick="wacCloseForm()" style="background:none;border:none;cursor:pointer;color:#7c3aed;font-size:1.1rem;padding:0;" aria-label="Voltar">←</button>
      <span style="font-size:.85rem;font-weight:700;color:#111;">Calcular frete</span>
    </div>
    <input id="wac-cep-input" type="text" placeholder="Digite seu CEP (ex: 74000-000)" maxlength="9"
      style="width:100%;border:1.5px solid #e5e7eb;border-radius:.75rem;padding:.6rem .875rem;font-size:.85rem;outline:none;font-family:inherit;box-sizing:border-box;"
      oninput="this.value=this.value.replace(/\D/g,'').replace(/^(\d{5})(\d)/,'$1-$2').substring(0,9)"
      onkeydown="if(event.key==='Enter')wacDoFrete()">
