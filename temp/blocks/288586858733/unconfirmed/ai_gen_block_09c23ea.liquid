  <div class="ai-editorial-grid-{{ ai_gen_id }}">
    {% if block.settings.featured_article != blank %}
      <article class="ai-editorial-card-{{ ai_gen_id }} ai-editorial-card-{{ ai_gen_id }}--featured">
        <div class="ai-editorial-image-wrapper-{{ ai_gen_id }}">
          {% if block.settings.featured_article.image %}
            <img
              src="{{ block.settings.featured_article.image | image_url: width: 1200 }}"
              alt="{{ block.settings.featured_article.image.alt | escape }}"
              class="ai-editorial-image-{{ ai_gen_id }}"
              loading="lazy"
              width="1200"
              height="800"
            >
          {% else %}
            <div class="ai-editorial-image-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
          {% if block.settings.show_category and block.settings.featured_article.tags.size > 0 %}
            <span class="ai-editorial-category-{{ ai_gen_id }}">{{ block.settings.featured_article.tags.first }}</span>
          {% endif %}
        </div>
        <div class="ai-editorial-content-{{ ai_gen_id }}">
          <h2 class="ai-editorial-title-{{ ai_gen_id }}">{{ block.settings.featured_article.title }}</h2>
          {% if block.settings.featured_article.excerpt != blank %}
            <div class="ai-editorial-excerpt-{{ ai_gen_id }}">{{ block.settings.featured_article.excerpt | strip_html | truncate: 180 }}</div>
          {% endif %}
          <div class="ai-editorial-meta-{{ ai_gen_id }}">
            {% if block.settings.show_author and block.settings.featured_article.author != blank %}
              <span class="ai-editorial-author-{{ ai_gen_id }}">{{ block.settings.featured_article.author }}</span>
            {% endif %}
            {% if block.settings.show_date %}
              <span class="ai-editorial-date-{{ ai_gen_id }}">{{ block.settings.featured_article.published_at | date: '%d %b %Y' }}</span>
            {% endif %}
          </div>
        </div>
        <a href="{{ block.settings.featured_article.url }}" class="ai-editorial-link-{{ ai_gen_id }}">{{ block.settings.featured_article.title }}</a>
      </article>
    {% endif %}

