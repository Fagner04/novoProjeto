{% if settings.popup_enabled %}
<div id="promo-popup-overlay" style="display:none;position:fixed;inset:0;z-index:9998;background:rgba(0,0,0,0.25);" onclick="closePromoPopup()"></div>

<div id="promo-popup" style="display:none;position:fixed;bottom:1.5rem;left:1.5rem;z-index:9999;max-width:340px;width:calc(100% - 3rem);">
  <div style="background:#fff;border-radius:1.25rem;padding:1.5rem;box-shadow:0 8px 40px rgba(0,0,0,0.18);position:relative;overflow:hidden;">

    <!-- Fundo gradiente sutil -->
    <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(113,68,155,0.06) 0%,rgba(254,126,65,0.06) 100%);pointer-events:none;"></div>

    <!-- Botão fechar -->
    <button onclick="closePromoPopup()" aria-label="Fechar" style="position:absolute;top:0.75rem;right:0.75rem;background:rgba(0,0,0,0.06);border:none;border-radius:50%;width:28px;height:28px;cursor:pointer;font-size:1rem;color:#52525b;display:flex;align-items:center;justify-content:center;line-height:1;">×</button>

    <!-- Badge -->
    <div style="display:inline-flex;align-items:center;gap:0.4rem;background:rgba(113,68,155,0.1);border-radius:9999px;padding:0.3rem 0.75rem;margin-bottom:0.85rem;">
      <span style="font-size:1rem;">{{ settings.popup_icon | default: '🎁' }}</span>
      <span style="font-size:0.65rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:#71449b;">{{ settings.popup_badge | default: 'Oferta Especial' }}</span>
    </div>

    <!-- Título -->
    {% if settings.popup_title != blank %}
      <p style="font-size:1rem;font-weight:700;color:#18181b;margin-bottom:0.5rem;line-height:1.3;">{{ settings.popup_title }}</p>
    {% endif %}

    <!-- Texto -->
    {% if settings.popup_text != blank %}
      <p style="font-size:0.875rem;color:#52525b;line-height:1.55;margin-bottom:1rem;">{{ settings.popup_text }}</p>
    {% endif %}

    <!-- Botão CTA -->
    {% if settings.popup_btn_label != blank %}
      <a href="{{ settings.popup_btn_url | default: '#' }}"
        style="display:block;text-align:center;background:linear-gradient(135deg,#71449b,#fe7e41);color:#fff;font-weight:600;font-size:0.875rem;padding:0.75rem 1rem;border-radius:9999px;text-decoration:none;">
        {{ settings.popup_btn_label }}
      </a>
    {% endif %}

  </div>
</div>

<script>
(function(){
  var KEY = '_promo_closed_{{ settings.popup_title | md5 | slice: 0, 8 }}';
  var delay = {{ settings.popup_delay | default: 3 }} * 1000;

  if(sessionStorage.getItem(KEY)) return;

  setTimeout(function(){
    document.getElementById('promo-popup').style.display = 'block';
    document.getElementById('promo-popup-overlay').style.display = 'block';
  }, delay);

  window.closePromoPopup = function(){
    document.getElementById('promo-popup').style.display = 'none';
    document.getElementById('promo-popup-overlay').style.display = 'none';
    sessionStorage.setItem(KEY, '1');
  };
})();
</script>
{% endif %}
