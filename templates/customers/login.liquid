<div class="auth-page">
  <div class="auth-card">

    <div class="auth-brand">
      <a href="/">
        {% if settings.logo != blank %}
          <img src="{{ settings.logo | image_url: width: 140 }}" alt="{{ shop.name }}" height="36">
        {% else %}
          <span class="auth-brand-name">{{ shop.name }}</span>
        {% endif %}
      </a>
    </div>

    <div class="auth-header">
      <h1>Bem-vinda de volta 👋</h1>
      <p>Entre na sua conta para ver seus pedidos e favoritos</p>
    </div>

    {% form 'customer_login' %}
      {% if form.errors %}
        <div class="auth-error">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          {{ form.errors | default_errors }}
        </div>
      {% endif %}

      <div class="auth-fields">
        <div class="auth-field">
          <label for="login-email">E-mail</label>
          <div class="auth-input-wrap">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <input id="login-email" type="email" name="customer[email]" placeholder="seu@email.com" autocomplete="email" required>
          </div>
        </div>
        <div class="auth-field">
          <div class="auth-field-row">
            <label for="login-pass">Senha</label>
            <a href="{{ routes.account_recover_url }}" class="auth-forgot">Esqueci minha senha</a>
          </div>
          <div class="auth-input-wrap">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            <input id="login-pass" type="password" name="customer[password]" placeholder="••••••••" autocomplete="current-password" required>
          </div>
        </div>
      </div>

      <button type="submit" class="auth-btn">Entrar na minha conta</button>

      <p class="auth-switch">Ainda não tem conta? <a href="{{ routes.account_register_url }}">Criar conta grátis</a></p>
    {% endform %}

    <div class="auth-divider"><span>ou continue como</span></div>
    <a href="/collections/all" class="auth-btn-ghost">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
      Continuar comprando
    </a>

  </div>
</div>
