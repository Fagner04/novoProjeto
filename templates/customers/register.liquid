<div class="auth-page">
  <div class="auth-card">

    <div class="auth-brand">
      <a href="/">
        {% if settings.logo != blank %}
          <img src="{{ settings.logo | image_url: width: 140 }}" alt="{{ shop.name }}" height="36">
        {% else %}
          <span class="auth-brand-name">{{ shop.name }}</span>
        {% endif %}
      </a>
    </div>

    <div class="auth-header">
      <h1>Criar sua conta ✨</h1>
      <p>Acompanhe seus pedidos e tenha uma experiência personalizada</p>
    </div>

    {% form 'create_customer' %}
      {% if form.errors %}
        <div class="auth-error">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          {{ form.errors | default_errors }}
        </div>
      {% endif %}

      <div class="auth-fields">
        <div class="auth-row-2">
          <div class="auth-field">
            <label for="reg-fname">Nome</label>
            <div class="auth-input-wrap">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              <input id="reg-fname" type="text" name="customer[first_name]" placeholder="Maria" autocomplete="given-name">
            </div>
          </div>
          <div class="auth-field">
            <label for="reg-lname">Sobrenome</label>
            <div class="auth-input-wrap">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              <input id="reg-lname" type="text" name="customer[last_name]" placeholder="Silva" autocomplete="family-name">
            </div>
          </div>
        </div>
        <div class="auth-field">
          <label for="reg-email">E-mail</label>
          <div class="auth-input-wrap">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <input id="reg-email" type="email" name="customer[email]" placeholder="seu@email.com" autocomplete="email" required>
          </div>
        </div>
        <div class="auth-field">
          <label for="reg-pass">Senha</label>
          <div class="auth-input-wrap">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            <input id="reg-pass" type="password" name="customer[password]" placeholder="Mínimo 5 caracteres" autocomplete="new-password" required>
          </div>
        </div>
      </div>

      <button type="submit" class="auth-btn">Criar minha conta</button>
      <p class="auth-switch">Já tem conta? <a href="{{ routes.account_login_url }}">Entrar</a></p>
    {% endform %}

  </div>
</div>
