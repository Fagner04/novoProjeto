<section class="hero-section">
  <div class="hero-carousel-wrap">
    <div class="hero-slides" id="hero-slides">
      {% for block in section.blocks %}
        <div class="hero-slide" {{ block.shopify_attributes }}>
          <div class="hero-bg hero-bg-mobile">
            {% if block.settings.image_mobile != blank %}
              <img src="{{ block.settings.image_mobile | image_url: width: 800 }}" alt="{{ block.settings.title | escape }}" loading="{% if forloop.first %}eager{% else %}lazy{% endif %}">
            {% elsif block.settings.image != blank %}
              <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.title | escape }}" loading="{% if forloop.first %}eager{% else %}lazy{% endif %}">
            {% else %}
              <div style="width:100%;height:100%;background:linear-gradient(135deg,#2d1f38,#4a3659);"></div>
            {% endif %}
            <div class="hero-overlay"></div>
          </div>
          <div class="hero-bg hero-bg-desktop">
            {% if block.settings.image != blank %}
              <img src="{{ block.settings.image | image_url: width: 1920 }}" alt="{{ block.settings.title | escape }}" loading="{% if forloop.first %}eager{% else %}lazy{% endif %}" fetchpriority="{% if forloop.first %}high{% else %}auto{% endif %}">
            {% else %}
              <div style="width:100%;height:100%;background:linear-gradient(135deg,#2d1f38,#4a3659);"></div>
            {% endif %}
            <div class="hero-overlay"></div>
          </div>
          <div class="hero-content">
            {% if block.settings.tagline != blank %}<p class="hero-tagline">{{ block.settings.tagline }}</p>{% endif %}
            {% if block.settings.title != blank %}<h2 class="hero-title">{{ block.settings.title }}</h2>{% endif %}
            {% if block.settings.subtitle != blank %}<p class="hero-subtitle">{{ block.settings.subtitle }}</p>{% endif %}
            <div class="hero-ctas">
              {% if block.settings.cta_text != blank %}<a href="{{ block.settings.cta_link | default: '/collections/all' }}" class="hero-cta-primary">{{ block.settings.cta_text }}</a>{% endif %}
              {% if block.settings.cta2_text != blank %}<a href="{{ block.settings.cta2_link | default: '/collections/all' }}" class="hero-cta-secondary">{{ block.settings.cta2_text }}</a>{% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
    {% if section.settings.promo_enabled %}
      <div class="hero-promo-card" id="hero-promo-card" style="background:{{ section.settings.promo_bg }};color:{{ section.settings.promo_text_color }};">
        <button class="hero-promo-close" onclick="document.getElementById('hero-promo-card').style.display='none'" aria-label="Fechar">✕</button>
        {% if section.settings.promo_badge != blank %}
          <p class="hero-promo-badge" style="color:{{ section.settings.promo_badge_color }};">{{ section.settings.promo_badge }}</p>
        {% endif %}
        {% if section.settings.promo_title != blank %}
          <p class="hero-promo-title">{{ section.settings.promo_title }}</p>
        {% endif %}
        {% if section.settings.promo_text != blank %}
          <p class="hero-promo-text">{{ section.settings.promo_text }}</p>
        {% endif %}
        {% if section.settings.promo_btn_text != blank %}
          <a href="{{ section.settings.promo_btn_link | default: '/collections/all' }}" class="hero-promo-btn" style="background:{{ section.settings.promo_btn_bg }};color:{{ section.settings.promo_btn_color }};">{{ section.settings.promo_btn_text }}</a>
        {% endif %}
      </div>
    {% endif %}
    {% if section.blocks.size > 1 %}
      <button class="hero-arrow hero-arrow-prev" onclick="heroSlide(-1)" aria-label="Anterior">&#8592;</button>
      <button class="hero-arrow hero-arrow-next" onclick="heroSlide(1)" aria-label="Próximo">&#8594;</button>
      <div class="hero-dots" id="hero-dots">
        {% for block in section.blocks %}
          <button class="hero-dot {% if forloop.first %}active{% endif %}" onclick="heroGoTo({{ forloop.index0 }})" aria-label="Slide {{ forloop.index }}"></button>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

<script>
var heroIndex=0,heroTotal={{ section.blocks.size }},heroTimer;
function heroGoTo(i){heroIndex=i;document.querySelectorAll('.hero-slide').forEach(function(s,j){s.classList.toggle('active',j===i);});document.querySelectorAll('.hero-dot').forEach(function(d,j){d.classList.toggle('active',j===i);});}
function heroSlide(d){heroGoTo((heroIndex+d+heroTotal)%heroTotal);resetHeroTimer();}
function resetHeroTimer(){clearInterval(heroTimer);if(heroTotal>1)heroTimer=setInterval(function(){heroSlide(1);},5000);}
document.addEventListener('DOMContentLoaded',function(){heroGoTo(0);resetHeroTimer();});
</script>

{% schema %}
{
  "name": "Hero Banner",
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Imagem desktop" },
        { "type": "image_picker", "id": "image_mobile", "label": "Imagem mobile" },
        { "type": "text", "id": "tagline", "label": "Tagline" },
        { "type": "text", "id": "title", "label": "Título" },
        { "type": "textarea", "id": "subtitle", "label": "Subtítulo" },
        { "type": "text", "id": "cta_text", "label": "Botão 1 - Texto", "default": "Ver Coleção" },
        { "type": "url", "id": "cta_link", "label": "Botão 1 - Link" },
        { "type": "text", "id": "cta2_text", "label": "Botão 2 - Texto" },
        { "type": "url", "id": "cta2_link", "label": "Botão 2 - Link" }
      ]
    }
  ],
  "presets": [{ "name": "Hero Banner", "blocks": [{ "type": "slide" }] }],
  "settings": [
    { "type": "header", "content": "Card de Oferta" },
    { "type": "checkbox", "id": "promo_enabled", "label": "Exibir card de oferta", "default": false },
    { "type": "text", "id": "promo_badge", "label": "Badge (ex: ✨ OFERTA ESPECIAL ✨)", "default": "✨ OFERTA ESPECIAL ✨" },
    { "type": "text", "id": "promo_title", "label": "Título do card", "default": "Feliz dia das mulheres 😍" },
    { "type": "textarea", "id": "promo_text", "label": "Texto da oferta", "default": "Cada peça é um presente de força e beleza!" },
    { "type": "text", "id": "promo_btn_text", "label": "Texto do botão", "default": "Ver Oferta" },
    { "type": "url", "id": "promo_btn_link", "label": "Link do botão" },
    { "type": "color", "id": "promo_bg", "label": "Fundo do card", "default": "#ffffff" },
    { "type": "color", "id": "promo_text_color", "label": "Cor do texto", "default": "#18181b" },
    { "type": "color", "id": "promo_badge_color", "label": "Cor do badge", "default": "#7c3aed" },
    { "type": "color", "id": "promo_btn_bg", "label": "Fundo do botão", "default": "#fe7e41" },
    { "type": "color", "id": "promo_btn_color", "label": "Cor do texto do botão", "default": "#ffffff" }
  ]
}
{% endschema %}
