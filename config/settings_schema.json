  {
    "name": "Popup Promocional",
    "settings": [
      { "type": "checkbox", "id": "popup_enabled", "label": "Ativar popup promocional", "default": false },
      { "type": "text", "id": "popup_icon", "label": "Emoji do ícone", "default": "🎁" },
      { "type": "text", "id": "popup_badge", "label": "Texto do badge", "default": "Oferta Especial" },
      { "type": "text", "id": "popup_title", "label": "Título", "default": "Promoção exclusiva!" },
      { "type": "textarea", "id": "popup_text", "label": "Texto da oferta", "default": "Aproveite nossas ofertas especiais com frete grátis acima de R$299." },
      { "type": "text", "id": "popup_btn_label", "label": "Texto do botão", "default": "Ver ofertas" },
      { "type": "url", "id": "popup_btn_url", "label": "Link do botão" },
      { "type": "range", "id": "popup_delay", "label": "Aparecer após (segundos)", "min": 0, "max": 30, "step": 1, "default": 3 },
      { "type": "range", "id": "popup_hide_after", "label": "Desaparecer após (segundos)", "min": 3, "max": 60, "step": 1, "default": 8 },
      { "type": "range", "id": "popup_repeat_after", "label": "Repetir a cada (minutos)", "min": 1, "max": 60, "step": 1, "default": 5 }
    ]
  },
  {
    "name": "Chat WhatsApp",
    "settings": [
      { "type": "checkbox", "id": "wa_enabled", "label": "Ativar chat WhatsApp", "default": true },
      { "type": "text", "id": "wa_number", "label": "Número WhatsApp (com DDI)", "default": "5562994319090", "info": "Ex: 5562994319090 (sem + ou espaços)" },
      { "type": "text", "id": "wa_agent_name", "label": "Nome do atendente", "default": "Musas Atendimento" },
      { "type": "text", "id": "wa_status", "label": "Status exibido (quando offline)", "default": "Offline" },
      { "type": "header", "content": "Horário de Atendimento" },
      { "type": "paragraph", "content": "O status 'Online' aparece automaticamente dentro do horário configurado. Fora do horário exibe o status offline acima." },
      { "type": "checkbox", "id": "wa_schedule_enabled", "label": "Ativar status automático por horário", "default": true },
      { "type": "select", "id": "wa_tz_offset", "label": "Fuso horário", "default": "-3",
        "options": [
          { "value": "-5", "label": "UTC-5 (Acre)" },
          { "value": "-4", "label": "UTC-4 (Amazonas)" },
          { "value": "-3", "label": "UTC-3 (Brasília)" },
          { "value": "-2", "label": "UTC-2 (Fernando de Noronha)" }
        ]
      },
      { "type": "text", "id": "wa_hours_weekday", "label": "Horário Seg–Sex", "default": "09:00-18:00", "info": "Formato HH:MM-HH:MM. Ex: 09:00-18:00" },
      { "type": "text", "id": "wa_hours_saturday", "label": "Horário Sábado", "default": "10:00-14:00", "info": "Deixe vazio para não atender aos sábados" },
      { "type": "text", "id": "wa_hours_sunday", "label": "Horário Domingo", "default": "fechado", "info": "Deixe 'fechado' para não atender aos domingos" },
      { "type": "text", "id": "wa_status_online", "label": "Texto quando online", "default": "Online agora" },
      { "type": "header", "content": "Mensagens" },
      { "type": "textarea", "id": "wa_welcome", "label": "Mensagem de boas-vindas", "default": "👋 Olá! Bem-vindo à Musas! Como posso ajudar você hoje?" },
      { "type": "text", "id": "wa_default_msg", "label": "Mensagem padrão (campo vazio)", "default": "Olá! Vim pelo site e gostaria de mais informações." },
      { "type": "text", "id": "wa_footer", "label": "Texto do rodapé", "default": "Resposta em até 2 horas durante horário comercial" },
      { "type": "header", "content": "Bolinha de mensagem (ciclo)" },
      { "type": "textarea", "id": "wa_bubble_messages", "label": "Mensagens do ciclo (uma por linha)", "default": "Precisa rastrear seu pedido? 📦\nFrete grátis acima de R$299! 🚚\nTroca fácil em até 30 dias! 🔄" },
      { "type": "range", "id": "wa_show_delay", "label": "Aparecer após (segundos)", "min": 1, "max": 30, "step": 1, "default": 3 },
      { "type": "range", "id": "wa_hide_after", "label": "Sumir após (segundos)", "min": 2, "max": 20, "step": 1, "default": 5 },
      { "type": "range", "id": "wa_repeat_after", "label": "Repetir a cada (segundos)", "min": 5, "max": 120, "step": 5, "default": 30 }
    ]
  },
  {
    "name": "Atacado (ConectWhats)",
    "settings": [
      { "type": "header", "content": "Configurações de Atacado" },
      { "type": "checkbox", "id": "conectwhats_atacado_enabled", "label": "Ativar barra de progresso de atacado", "default": false },
      { "type": "number", "id": "conectwhats_atacado_min_qty", "label": "Quantidade mínima para atacado", "default": 6 },
      { "type": "header", "content": "Acessórios — Regra de Mínimo" },
      { "type": "paragraph", "content": "Acessórios com a tag abaixo só recebem preço de atacado se o valor total deles no carrinho atingir o mínimo configurado. Abaixo do mínimo, cobra preço de varejo." },
      { "type": "checkbox", "id": "atacado_acessorio_enabled", "label": "Ativar regra de mínimo para acessórios", "default": false },
      { "type": "text", "id": "atacado_acessorio_tag", "label": "Tag dos produtos acessórios", "default": "acessorio", "info": "Adicione esta tag nos produtos acessórios no painel do Shopify" },
      { "type": "text", "id": "atacado_acessorio_min_value", "label": "Valor mínimo de acessórios para atacado (R$)", "default": "100.00", "info": "Ex: 100.00 — abaixo deste valor cobra preço de varejo" },
      { "type": "text", "id": "atacado_acessorio_msg", "label": "Mensagem de aviso no carrinho", "default": "Valor mínimo deste produto" }
    ]
  },
  {
    "name": "Frete e Rastreio",
    "settings": [
      { "type": "header", "content": "Cálculo de Frete via Planilha Google Sheets" },
      { "type": "paragraph", "content": "Configure uma planilha do Google Sheets como banco de dados de frete. Crie um Google Apps Script, configure as regras de frete por CEP/região e publique como Web App." },
      { "type": "checkbox", "id": "frete_planilha_enabled", "label": "Ativar cálculo de frete via planilha", "default": false },
      { "type": "text", "id": "frete_planilha_url", "label": "URL da API do Google Sheets (Apps Script)", "info": "Cole aqui a URL do Google Apps Script publicado como Web App" },
      { "type": "header", "content": "Rastreio de Pedidos" },
      { "type": "paragraph", "content": "Permite que o cliente rastreie o pedido diretamente pelo site informando o código de rastreio." },
      { "type": "checkbox", "id": "rastreio_enabled", "label": "Ativar rastreio de pedidos", "default": false },
      { "type": "select", "id": "rastreio_carrier", "label": "Transportadora padrão", "default": "correios",
        "options": [
          { "value": "correios", "label": "Correios" },
          { "value": "jadlog", "label": "Jadlog" },
          { "value": "total_express", "label": "Total Express" },
          { "value": "custom", "label": "URL personalizada" }
        ]
      },
      { "type": "text", "id": "rastreio_custom_url", "label": "URL personalizada de rastreio", "info": "Use {codigo} como placeholder. Ex: https://minhalogistica.com/rastrear/{codigo}" }
    ]
  }
]
