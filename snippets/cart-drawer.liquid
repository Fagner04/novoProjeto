<div class="cart-overlay" id="cart-overlay" onclick="closeCart()"></div>

<div class="cart-drawer" id="cart-drawer" aria-label="Carrinho">
  <div class="cart-drawer-header">
    <h2>Carrinho</h2>
    <button class="cart-close" onclick="closeCart()" aria-label="Fechar carrinho">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <div class="cart-items" id="cart-items-list">
    <!-- Populated by JS -->
    <div class="cart-empty" id="cart-empty">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color:var(--muted-foreground)">
        <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/>
        <path d="M16 10a4 4 0 0 1-8 0"/>
      </svg>
      <p>Seu carrinho está vazio</p>
      <a href="/collections/all" onclick="closeCart()" class="btn-primary btn-musas" style="border-radius:9999px;font-size:0.75rem;padding:0.75rem 1.5rem;">Ver Produtos</a>
    </div>
  </div>

  <div class="cart-footer" id="cart-footer" style="display:none;">
    <div id="cw-wholesale-progress-container"></div>

    <!-- Aviso de mínimo de acessórios para atacado -->
    {% if settings.atacado_acessorio_enabled %}
    <div id="cart-acessorio-warning" style="display:none;margin-bottom:0.75rem;padding:0.75rem 1rem;background:#FFF7ED;border-radius:0.75rem;border-left:3px solid #F97316;">
      <div style="display:flex;align-items:flex-start;gap:0.5rem;">
        <span style="font-size:1.1rem;flex-shrink:0;">🏷️</span>
        <div>
          <p id="cart-acessorio-msg" style="font-size:0.8rem;font-weight:600;color:#9A3412;margin:0 0 0.4rem;"></p>
          <div style="background:#fed7aa;border-radius:9999px;height:6px;overflow:hidden;">
            <div id="cart-acessorio-bar" style="height:100%;background:#F97316;border-radius:9999px;transition:width 0.4s;width:0%;"></div>
          </div>
          <p id="cart-acessorio-sub" style="font-size:0.72rem;color:#C2410C;margin:0.3rem 0 0;"></p>
        </div>
      </div>
    </div>
    {% endif %}

    <div class="cart-total">
      <span>Total</span>
      <span id="cart-total-price">R$ 0,00</span>
    </div>
    <a href="/checkout" class="cart-checkout-btn" id="cart-checkout-btn">
      Finalizar Compra
    </a>
    <p style="font-size:0.75rem;color:var(--muted-foreground);text-align:center;margin-top:0.75rem;">
      🔒 Pagamento 100% seguro
    </p>
  </div>
</div>

{% if settings.atacado_acessorio_enabled %}
<script>
(function(){
  var ACESSORIO_TAG = {{ settings.atacado_acessorio_tag | json }};
  var ACESSORIO_MIN = {{ settings.atacado_acessorio_min_qty | default: 6 }};
  var ACESSORIO_MSG = {{ settings.atacado_acessorio_msg | default: 'Para comprar acessórios no atacado, o mínimo é {min} unidades de acessórios.' | json }};
  var IS_WHOLESALE = {{ customer.tags contains 'atacadista' | json }};

  function checkAcessorioRule(cartItems) {
    if (!IS_WHOLESALE) return;

    var warning = document.getElementById('cart-acessorio-warning');
    var msgEl = document.getElementById('cart-acessorio-msg');
    var barEl = document.getElementById('cart-acessorio-bar');
    var subEl = document.getElementById('cart-acessorio-sub');
    var checkoutBtn = document.getElementById('cart-checkout-btn');
    if (!warning) return;

    // Conta acessórios no carrinho
    var acessorioQty = 0;
    var hasAcessorio = false;
    cartItems.forEach(function(item) {
      var tags = (item.product_tags || item.tags || '').split(',').map(function(t){ return t.trim().toLowerCase(); });
      if (tags.indexOf(ACESSORIO_TAG.toLowerCase()) > -1) {
        hasAcessorio = true;
        acessorioQty += item.quantity;
      }
    });

    if (!hasAcessorio) {
      warning.style.display = 'none';
      if (checkoutBtn) { checkoutBtn.style.opacity = ''; checkoutBtn.style.pointerEvents = ''; checkoutBtn.textContent = 'Finalizar Compra'; }
      return;
    }

    var pct = Math.min(100, Math.round((acessorioQty / ACESSORIO_MIN) * 100));
    var faltam = Math.max(0, ACESSORIO_MIN - acessorioQty);
    var msg = ACESSORIO_MSG.replace('{min}', ACESSORIO_MIN);

    warning.style.display = 'block';
    msgEl.textContent = msg;
    barEl.style.width = pct + '%';

    if (faltam > 0) {
      subEl.textContent = 'Faltam ' + faltam + ' unidade' + (faltam > 1 ? 's' : '') + ' de acessórios (' + acessorioQty + '/' + ACESSORIO_MIN + ')';
      if (checkoutBtn) {
        checkoutBtn.style.opacity = '0.5';
        checkoutBtn.style.pointerEvents = 'none';
        checkoutBtn.textContent = 'Mínimo de acessórios não atingido';
      }
    } else {
      subEl.textContent = '✅ Mínimo atingido! (' + acessorioQty + ' unidades)';
      barEl.style.background = '#16a34a';
      if (checkoutBtn) {
        checkoutBtn.style.opacity = '';
        checkoutBtn.style.pointerEvents = '';
        checkoutBtn.textContent = 'Finalizar Compra';
      }
    }
  }

  // Expõe para ser chamado pelo renderCart do theme.js
  window.checkAcessorioRule = checkAcessorioRule;
})();
</script>
{% endif %}
