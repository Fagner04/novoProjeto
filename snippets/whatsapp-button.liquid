    <div style="display:flex;gap:.5rem;margin-top:.5rem;">
      <button onclick="wacDoFrete()" style="flex:1;padding:.65rem;background:linear-gradient(135deg,#5b21b6,#7c3aed);color:#fff;border:none;border-radius:.75rem;font-size:.82rem;font-weight:700;cursor:pointer;font-family:inherit;">
        📦 Calcular
      </button>
      <button onclick="wacSend('Quero calcular o frete para o CEP: '+document.getElementById('wac-cep-input').value)" title="Perguntar pelo WhatsApp"
        style="padding:.65rem .85rem;background:#25D366;color:#fff;border:none;border-radius:.75rem;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <svg width="20" height="20" viewBox="0 0 32 32" fill="none"><path d="M16 2C8.268 2 2 8.268 2 16c0 2.478.648 4.805 1.782 6.82L2 30l7.38-1.754A13.94 13.94 0 0 0 16 30c7.732 0 14-6.268 14-14S23.732 2 16 2z" fill="#fff" fill-opacity=".25"/><path d="M23.1 19.6c-.3-.15-1.77-.87-2.04-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.27-.47-2.42-1.49-.9-.8-1.5-1.78-1.68-2.08-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.51-.17-.01-.37-.01-.57-.01-.2 0-.52.07-.8.37-.27.3-1.04 1.02-1.04 2.48 0 1.46 1.07 2.87 1.22 3.07.15.2 2.1 3.2 5.08 4.49.71.31 1.27.49 1.7.63.72.23 1.37.2 1.88.12.57-.09 1.77-.72 2.02-1.42.25-.7.25-1.3.17-1.42-.07-.12-.27-.2-.57-.35z" fill="#fff"/></svg>
      </button>
    </div>
  </div>

  <div class="wac-inp" id="wac-inp-default">
    <textarea class="wac-ta" id="wac-ta" placeholder="Digite sua mensagem..." rows="2"></textarea>
    <button class="wac-sbtn" onclick="wacSendCustom()">
      <svg width="18" height="18" viewBox="0 0 48 48" fill="none"><path d="M24 4C12.954 4 4 12.954 4 24c0 3.59.94 6.96 2.584 9.876L4 44l10.376-2.72A19.88 19.88 0 0 0 24 44c11.046 0 20-8.954 20-20S35.046 4 24 4z" fill="#fff" fill-opacity=".2"/><path d="M34.507 29.13c-.448-.224-2.652-1.308-3.063-1.457-.41-.149-.708-.224-1.007.224-.298.448-1.156 1.457-1.417 1.755-.261.298-.522.336-.97.112-2.67-1.335-4.424-2.382-6.186-5.4-.467-.803.467-.746 1.335-2.484.149-.298.075-.559-.037-.783-.112-.224-1.007-2.428-1.38-3.323-.364-.87-.733-.75-1.007-.764-.261-.013-.559-.016-.857-.016-.298 0-.783.112-1.193.559-.41.448-1.566 1.53-1.566 3.73 0 2.2 1.604 4.327 1.828 4.625.224.298 3.157 4.82 7.65 6.762 2.843 1.228 3.957.944 4.671.783.97-.224 2.652-1.084 3.025-2.132.373-1.048.373-1.946.261-2.132-.112-.186-.41-.298-.857-.522z" fill="#fff"/></svg>
      Enviar no WhatsApp
    </button>
  </div>
  <div class="wac-ft">{{ wa_footer }}</div>
</div>

<script>
(function(){
  var NUM='{{ wa_number }}';
  var SHOW_DELAY={{ wa_show_delay }}*1000;
  var HIDE_AFTER={{ wa_hide_after }}*1000;
  var REPEAT_AFTER={{ wa_repeat_after }}*1000;
  var WELCOME='{{ wa_welcome | escape }}';
  var DEFAULT_MSG='{{ wa_default_msg | escape }}';
  var STATUS_OFFLINE='{{ wa_status | escape }}';
  var STATUS_ONLINE='{{ wa_status_online | escape }}';
  var SCHEDULE_ENABLED={{ wa_schedule_enabled }};
  var TZ_OFFSET=parseInt('{{ wa_tz_offset }}')||(-3);
  var HOURS={
    weekday:'{{ wa_hours_weekday | escape }}',
    saturday:'{{ wa_hours_saturday | escape }}',
    sunday:'{{ wa_hours_sunday | escape }}'
  };

  // ---- Status automático por horário ----
  function parseRange(str){
    if(!str)return null;
    var p=str.split('-');
    if(p.length<2)return null;
    function toMin(t){var x=t.split(':');return parseInt(x[0])*60+(parseInt(x[1])||0);}
    return{start:toMin(p[0]),end:toMin(p[1])};
  }
  function isOnline(){
    if(!SCHEDULE_ENABLED)return false;
    var now=new Date();
    var utc=now.getTime()+now.getTimezoneOffset()*60000;
    var local=new Date(utc+TZ_OFFSET*3600000);
    var dow=local.getDay(); // 0=dom,6=sab
    var mins=local.getHours()*60+local.getMinutes();
    var rangeStr=dow===0?HOURS.sunday:dow===6?HOURS.saturday:HOURS.weekday;
    var range=parseRange(rangeStr);
    return range&&mins>=range.start&&mins<range.end;
  }
  function applyStatus(){
    var online=isOnline();
    var dot=document.querySelector('.wac-hdr-dot');
    var txt=document.getElementById('wac-status-text');
    if(dot)dot.style.background=online?'#4ade80':'#f87171';
    if(txt)txt.textContent=online?STATUS_ONLINE:STATUS_OFFLINE;
  }
  applyStatus();
  setInterval(applyStatus,60000); // atualiza a cada minuto

  var h=new Date().getHours();
  var greeting=h>=5&&h<12?'Bom dia! ☀️':h>=12&&h<18?'Boa tarde! 👋':'Boa noite! 🌙';

  var rawMsgs={{ settings.wa_bubble_messages | default: 'Precisa rastrear seu pedido? 📦\nFrete grátis acima de R$299! 🚚\nTroca fácil em até 30 dias! 🔄' | newline_to_br | split: '<br />' | json }};
  var msgs=rawMsgs.map(function(m){return m.replace(/\r?\n/g,'').trim();}).filter(Boolean);

  var KEY='wac_idx',idx=0;
  try{var s=parseInt(localStorage.getItem(KEY),10);if(!isNaN(s)&&msgs.length>0)idx=(s+1)%msgs.length;}catch(e){}

  var hideT,repeatT,opened=false;

  function showBubble(){
    var panel=document.getElementById('wac-panel');
    if(panel&&panel.classList.contains('open'))return;
    var wrap=document.getElementById('wac-bwrap');
    var dots=document.getElementById('wac-bdots');
    var txt=document.getElementById('wac-btext');
    if(!wrap||!dots||!txt)return;

    var msg=msgs.length>0?msgs[idx%msgs.length]:greeting;
    try{localStorage.setItem(KEY,idx%(msgs.length||1));}catch(e){}
    idx++;

    txt.style.display='none';
    dots.style.display='flex';
    wrap.classList.add('show');

    clearTimeout(hideT);
    hideT=setTimeout(function(){
      dots.style.display='none';
      txt.textContent=msg;
      txt.style.display='block';

      hideT=setTimeout(function(){
        wrap.classList.remove('show');
        setTimeout(function(){
          txt.style.display='none';
          dots.style.display='none';
        },400);
        clearTimeout(repeatT);
        repeatT=setTimeout(showBubble,REPEAT_AFTER);
      },HIDE_AFTER);
    },1400);
  }

  function hideBubble(){
    var wrap=document.getElementById('wac-bwrap');
    if(wrap)wrap.classList.remove('show');
    clearTimeout(hideT);clearTimeout(repeatT);
  }

  setTimeout(showBubble,SHOW_DELAY);

  window.wacToggle=function(){
    var panel=document.getElementById('wac-panel');
    var fab=document.getElementById('wac-fab');
    var isOpen=panel.classList.toggle('open');
    fab.classList.toggle('is-open',isOpen);
    document.getElementById('wac-icon-wa').style.display=isOpen?'none':'block';
    document.getElementById('wac-icon-close').style.display=isOpen?'block':'none';
    hideBubble();
    if(isOpen&&!opened){opened=true;showWelcome();}
  };

  function showWelcome(){
    var msgs_el=document.getElementById('wac-msgs');
    if(!msgs_el)return;
    var typing=document.createElement('div');
    typing.className='wac-typing-bubble';
    typing.innerHTML='<span></span><span></span><span></span>';
    msgs_el.appendChild(typing);
    msgs_el.scrollTop=msgs_el.scrollHeight;

    setTimeout(function(){
      msgs_el.removeChild(typing);
      var div=document.createElement('div');
      div.className='wac-msg';
      div.innerHTML=WELCOME+'<div class="wac-msg-time">'+greeting+'</div>';
      msgs_el.appendChild(div);
      msgs_el.scrollTop=msgs_el.scrollHeight;
    },1500);
  }

  window.wacSend=function(msg){
    window.open('https://wa.me/'+NUM+'?text='+encodeURIComponent(msg),'_blank');
  };
  window.wacSendCustom=function(){
    var v=document.getElementById('wac-ta').value.trim();
    wacSend(v||DEFAULT_MSG);
  };

  // ---- Rastreio & Frete inline ----
  var FRETE_URL='{{ settings.frete_planilha_url | escape }}';

  function wacShowForm(id){
    document.getElementById('wac-quick-grid').style.display='none';
    document.getElementById('wac-inp-default').style.display='none';
    document.getElementById('wac-form-rastreio').style.display='none';
    document.getElementById('wac-form-frete').style.display='none';
    document.getElementById(id).style.display='block';
    var inp=document.querySelector('#'+id+' input');
    if(inp)setTimeout(function(){inp.focus();},100);
  }

  window.wacCloseForm=function(){
    document.getElementById('wac-form-rastreio').style.display='none';
    document.getElementById('wac-form-frete').style.display='none';
    document.getElementById('wac-quick-grid').style.display='grid';
    document.getElementById('wac-inp-default').style.display='block';
    var r=document.getElementById('wac-frete-result');
    if(r){r.style.display='none';r.innerHTML='';}
  };

  window.wacOpenRastreio=function(){wacShowForm('wac-form-rastreio');};
  window.wacOpenFrete=function(){wacShowForm('wac-form-frete');};

  window.wacDoRastreio=function(){
    var code=document.getElementById('wac-rastreio-input').value.trim().replace(/\s/g,'').toUpperCase();
    if(!code){alert('Digite o código de rastreio.');return;}
    window.open('https://rastreamento.correios.com.br/app/index.php?objeto='+encodeURIComponent(code),'_blank');
  };

  window.wacDoFrete=function(){
    var cep=document.getElementById('wac-cep-input').value.replace(/\D/g,'');
    if(cep.length!==8){alert('CEP inválido. Digite 8 dígitos.');return;}
    var result=document.getElementById('wac-frete-result');
    if(!FRETE_URL){
      result.innerHTML='⚠️ URL da planilha não configurada. Acesse a engrenagem do tema e preencha a URL do Google Apps Script.';
      result.style.display='block';return;
    }
    result.innerHTML='⏳ Consultando endereço...';
    result.style.display='block';

    // Busca endereço no ViaCEP primeiro
    fetch('https://viacep.com.br/ws/'+cep+'/json/')
      .then(function(r){return r.json();})
      .then(function(addr){
        var addrHtml='';
        if(!addr.erro){
          var partes=[addr.logradouro,addr.bairro,addr.localidade+(addr.uf?' - '+addr.uf:'')].filter(Boolean);
          addrHtml='<div style="padding:5px 0 8px;border-bottom:1px solid #e5e7eb;margin-bottom:8px;font-size:.78rem;color:#374151;">'
            +'<span style="font-size:.7rem;color:#9ca3af;display:block;margin-bottom:2px;">📍 Entrega para:</span>'
            +'<strong>'+partes.join(', ')+'</strong>'
            +'</div>';
        }
        result.innerHTML=addrHtml+'⏳ Calculando frete...';

        return fetch(FRETE_URL+'?cep='+cep)
          .then(function(r){return r.json();})
          .then(function(data){
            var freteHtml='';
            if(!data.success && data.error){
              freteHtml='❌ '+data.error;
            } else if(data.options && data.options.length>0){
              freteHtml='<p style="font-weight:700;margin:0 0 6px;font-size:.82rem;">📦 Opções de frete:</p>';
              data.options.forEach(function(op){
                var price=typeof op.price==='number'?'R$ '+op.price.toFixed(2).replace('.',','):op.price;
                freteHtml+='<div style="display:flex;justify-content:space-between;align-items:center;padding:5px 0;border-bottom:1px solid #f0f0f0;">'
                  +'<div><strong style="font-size:.82rem;">'+op.name+'</strong><br><span style="font-size:.72rem;color:#6b7280;">'+op.estimated_days+'</span></div>'
                  +'<strong style="color:#7c3aed;font-size:.85rem;">'+price+'</strong>'
                  +'</div>';
              });
            } else if(data.frete!==undefined){
              var valor=typeof data.frete==='number'?'R$ '+data.frete.toFixed(2).replace('.',','):data.frete;
              freteHtml='✅ <strong>Frete: '+valor+'</strong>'+(data.prazo?' • '+data.prazo+' dias úteis':'');
            } else {
              freteHtml='<pre style="font-size:11px;white-space:pre-wrap;">'+JSON.stringify(data,null,2)+'</pre>';
            }
            result.innerHTML=addrHtml+freteHtml;
          });
      })
      .catch(function(){
        result.innerHTML='❌ Erro ao consultar. Verifique a URL da planilha ou tente pelo WhatsApp.';
      });
    // dummy return para não quebrar o .then/.catch abaixo (removido — lógica acima é self-contained)
    return;
  };
})();
</script>
{% endif %}
